doctype html
html(lang='ru')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title Проекты — it.dimazvali.com
    link(rel='icon' type='image/x-icon' href='/images/dimazvali/favicon.ico')
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
    link(href='https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500;700&display=swap' rel='stylesheet')
    link(rel='stylesheet' href='/stylesheets/it/style.css')
    script(async src='https://www.googletagmanager.com/gtag/js?id=G-LDMN4XFB42')
    script.
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LDMN4XFB42');

  body

    header.site-header
      div.site-logo it.dimazvali.com
      a.site-back(href='https://dimazvali.com') ← dimazvali.com

    section.hero
      div.hero-eyebrow IT &amp; проджект-менеджмент
      h1.hero-title
        | Проекты
        br
        | и&nbsp;продукты
      p.hero-desc То, что я&nbsp;собираю днём: продукты, команды и&nbsp;запуски. Здесь — короткие карточки проектов; некоторые со&nbsp;временем дорастут до&nbsp;полных историй.

    section.filter-section
      - var allTags = ['все', 'разработка', 'менеджмент', 'продюсирование', 'фан', 'медиа']
      div.filter-bar
        span.filter-label Фильтр
        div.filter-tags
          each tag in allTags
            button.tag-btn(data-tag=tag)= tag
        span#count.filter-count

    section.projects-section
      div#grid.projects-grid
        each p in projects
          article.project-card(data-tags=p.tags.join(','))
            if p.cover
              div.card-cover
                img(src=p.cover alt=p.name)
            else
              div.card-placeholder
                div.card-placeholder-url it.dimazvali.com/#{p.slug}
                div.card-placeholder-name= p.name
                div.card-placeholder-diamond ◆
            div.card-body
              div.card-tags
                each tag in p.tags
                  span.card-tag= tag
              if p.cover
                h3.card-title= p.name
              p.card-desc= p.short
              if p.full
                a.card-link(href='/'+p.slug)
                  | Подробнее&nbsp;
                  span →
              else if p.link
                a.card-link(href=p.link target='_blank' rel='noopener noreferrer')
                  | Открыть проект&nbsp;
                  span ↗

    div.wip-banner
      div.wip-banner-inner в разработке

    footer
      div.footer-inner
        div
          div.footer-cta-label Связаться
          div.footer-cta-title Обсудить проект
        div.footer-contacts
          a.footer-contact-row(href='mailto:dimazvali@gmail.com')
            span.footer-contact-type email
            span dimazvali@gmail.com
          a.footer-contact-row(href='https://telegram.me/dimazvali')
            span.footer-contact-type telegram
            span @dimazvali
      div.footer-bottom
        div.footer-bottom-inner
          span © it.dimazvali.com
          span გამარჯობა!

    script.
      (function() {
        var active = 'все';
        var cards = Array.from(document.querySelectorAll('.project-card'));
        var btns = Array.from(document.querySelectorAll('.tag-btn'));
        var countEl = document.getElementById('count');

        function wordForm(n) {
          return n === 1 ? 'проект' : (n >= 2 && n <= 4 ? 'проекта' : 'проектов');
        }

        function setFilter(tag) {
          active = tag;
          var visible = 0;
          cards.forEach(function(card) {
            var tags = card.dataset.tags.split(',');
            var show = tag === 'все' || tags.indexOf(tag) !== -1;
            card.style.display = show ? 'flex' : 'none';
            if (show) visible++;
          });
          countEl.textContent = visible + ' ' + wordForm(visible);
          btns.forEach(function(btn) {
            var on = btn.dataset.tag === tag;
            btn.style.background = on ? '#15120f' : 'transparent';
            btn.style.color = on ? '#f4f1ea' : '#56514a';
            btn.style.borderColor = on ? '#15120f' : '#c8c3b8';
          });
        }

        btns.forEach(function(btn) {
          btn.addEventListener('click', function() { setFilter(btn.dataset.tag); });
        });

        setFilter('все');
      })();
