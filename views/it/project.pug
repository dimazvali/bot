doctype html
html(lang='ru')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title #{project.metaTitle || project.name} — it.dimazvali.com
    if project.metaDescription
      meta(name='description' content=project.metaDescription)
    link(rel='icon' type='image/x-icon' href='/images/dimazvali/favicon.ico')
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
    link(href='https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500;700&display=swap' rel='stylesheet')
    link(rel='stylesheet' href='/stylesheets/it/style.css')
    script(async src='https://www.googletagmanager.com/gtag/js?id=G-LDMN4XFB42')
    script.
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LDMN4XFB42');

  body

    header.project-header
      a.project-back(href='/') ← Проекты
      div.project-wordmark it.dimazvali.com

    section.project-intro
      div.project-intro-tags
        each tag in project.tags
          span.project-intro-tag= tag
      h1.project-title= project.name
      p.project-short= project.short

    section.project-meta-section
      div.project-meta-grid
        if project.role
          div.project-meta-cell
            div.project-meta-label Роль
            div.project-meta-value= project.role
        if project.period
          div.project-meta-cell
            div.project-meta-label Период
            div.project-meta-value= project.period
        if project.stack
          div.project-meta-cell
            div.project-meta-label Стек / инструменты
            div.project-meta-value= project.stack
        if project.link
          div.project-meta-cell
            div.project-meta-label Ссылка
            a.project-meta-link(href=project.link target='_blank')
              | Открыть&nbsp;
              span ↗

    if project.cover
      figure.project-cover-figure
        div.project-cover-wrap
          img(src=project.cover alt=project.name)

    article.project-article
      if project.context && project.context.length
        h2.project-section-title Контекст
        each para in project.context
          div.project-content!= para

      if project.quote
        blockquote.project-quote
          p!= project.quote

      if project.actions && project.actions.length
        h2.project-section-title Что я сделал
        ul.project-actions
          each action, i in project.actions
            li.project-action
              span.project-action-num= ('0' + (i + 1)).slice(-2)
              span!= action

    if project.result
      article.project-article-bottom
        h2.project-section-title Результат
        div.project-content!= project.result
        if project.metrics && project.metrics.length
          div.project-metrics
            each m in project.metrics
              div.project-metric
                div.project-metric-value= m.value
                div.project-metric-label= m.label

    if project.details && project.details.length
      article.project-article
        h2.project-section-title Детали
      each detail in project.details
        article.project-article
          h3.project-detail-title!= detail.title
          div.project-content!= detail.desc || ''

    if related && related.length
      section.related-section
        div.related-label Другие истории этого проекта
        div.related-grid
          each r in related
            a.related-card(href='/' + r.slug)
              if r.cover
                div.related-card-cover: img(src=r.cover alt=r.name)
              div.related-card-body
                div.related-card-name= r.name
                if r.short
                  div.related-card-short= r.short

    div.wip-banner
      div.wip-banner-inner в разработке

    footer
      a.project-footer-nav(href='/')
        div.project-footer-nav-inner
          div
            div.project-footer-nav-label Дальше
            div.project-footer-nav-title Все проекты
          span.project-footer-nav-arrow →
      div.project-footer-bottom
        span © it.dimazvali.com
        a(href='mailto:dimazvali@gmail.com') dimazvali@gmail.com
