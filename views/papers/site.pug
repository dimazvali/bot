doctype html
html(lang=lang || 'ru')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title= title || 'Papers'
    meta(name='yandex-verification' content='475ef9740ed79940')
    meta(name='description' content!=(clearTags && clearTags(description) || 'Коворкинг, лекторий, бар, подкаст-студия.'))
    meta(property='og:title' content=(title || 'Papers Kartuli'))
    meta(property='og:description' content!=(clearTags && clearTags(description) || 'Коворкинг, лекторий, бар, подкаст-študia.'))
    link(rel='icon' type='image/x-icon' href='/images/papers/favicon.ico')
    if image
      meta(property='og:image' content=image)
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
    link(href='https://fonts.googleapis.com/css2?family=Literata:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Onest:wght@400;500;600;700&display=swap' rel='stylesheet')
    link(rel='stylesheet' href='/stylesheets/papers/style.css')
    script(async src='https://www.googletagmanager.com/gtag/js?id=G-W6S5THCFFH')
    script.
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W6S5THCFFH');
  body
    nav.p-nav
      .p-nav-left
        a.p-logo(href='/')
          | Papers
          span.p-logo-dot .
        .p-nav-links
          - var isRu = lang !== 'en'
          a(href='/' data-nav-path='/')= isRu ? 'Расписание' : 'Schedule'
          a(href='/coworking' data-nav-path='/coworking')= isRu ? 'Коворкинг' : 'Coworking'
          a(href='/authors' data-nav-path='/authors')= isRu ? 'Резиденты' : 'Residents'
          a(href='/bar' data-nav-path='/bar')= isRu ? 'Бар' : 'Bar'
          a(href='/staff' data-nav-path='/staff')= isRu ? 'Контакты' : 'Contacts'
      .p-nav-right
        .p-lang-toggle
          button.p-lang-btn(class=(lang !== 'en' ? 'p-lang-active' : '') onclick="switchLang('ru')") RU
          button.p-lang-btn(class=(lang === 'en' ? 'p-lang-active' : '') onclick="switchLang('en')") EN
    block content
    footer.p-footer
      span © Papers Space
      a(href='https://t.me/paperstuffbot' target='_blank') Telegram
    script.
      function switchLang(l) {
        var u = new URL(window.location.href);
        u.searchParams.set('lang', l);
        window.location.href = u.toString();
      }
      (function() {
        var path = window.location.pathname.replace(/\/$/, '') || '/';
        document.querySelectorAll('[data-nav-path]').forEach(function(a) {
          var np = a.dataset.navPath;
          if (np === '/' ? path === '/' || path.startsWith('/classes') : path.startsWith(np)) {
            a.classList.add('p-nav-active');
          }
        });
      })();
