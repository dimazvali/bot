extends layout

block content
  .photo-page
    .photo-page-back
      a(href=`/${countryKey}/${seriesKey}`) ← #{seriesLabel.toUpperCase()}
      if isAdmin
        .admin-bar
          a.admin-bar-btn(href=`/admin/${countryKey}/${seriesKey}/${photo.id}/edit`) ✎ редактировать
          a.admin-bar-btn(href=`/admin/${countryKey}/${seriesKey}/upload`) + фото
    .photo-page-image
      .photo-page-bg(style=`background-image: url(${photo.urls ? photo.urls.full : '/images/photo/' + countryKey + '/' + seriesKey + '/' + photo.file})`)
      img(
        src=photo.urls ? photo.urls.full : `/images/photo/${countryKey}/${seriesKey}/${photo.file}`
        alt=photo.title
        onerror="this.style.background='#1e1e1e';this.removeAttribute('src')"
      )
    .photo-page-info
      .photo-page-meta
        h1.photo-page-title= photo.title
        .photo-page-loc #{countryLabel.toUpperCase()} · #{seriesLabel.toUpperCase()}#{photo.date ? ' · ' + photo.date : ''}
      .photo-page-nav
        if prev
          a.nav-btn(href=`/${countryKey}/${seriesKey}/${prev.id}` data-dir='prev') ← ПРЕД.
        if next
          a.nav-btn(href=`/${countryKey}/${seriesKey}/${next.id}` data-dir='next') СЛЕД. →
    if photo.desc
      p.photo-page-desc= photo.desc
    if photo.tags && photo.tags.length
      .photo-tags
        each tag in photo.tags
          a.photo-tag(href=`/tag/${tag}`)= allTags[tag] ? allTags[tag].label.toUpperCase() : tag.toUpperCase()
    .photo-actions
      button.action-btn(onclick='sharePhoto()') ПОДЕЛИТЬСЯ
      if photo.instagram
        a.action-btn(href=photo.instagram target='_blank' rel='noopener') INSTAGRAM
    if related && related.length
      .related
        .related-label ЕЩЁ ИЗ #{countryLabel.toUpperCase()}
        .related-strip
          each r in related
            a.related-thumb(href=`/${r.countryKey}/${r.seriesKey}/${r.id}` title=r.title)
              img(src=r.urls.preview alt=r.title loading='lazy' onerror="this.closest('.related-thumb').style.display='none'")
