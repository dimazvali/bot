extends layout
include mixins

block head
  if !isShoot
    -
      var _imgUrl = photo.urls ? (photo.urls.full || photo.urls.preview) : null
      var _ld = {
        '@context': 'https://schema.org',
        '@type': 'ImageObject',
        name: photo.title,
        contentUrl: _imgUrl,
        thumbnailUrl: photo.urls ? photo.urls.preview : null,
        url: 'https://photo.dimazvali.com/' + countryKey + '/' + seriesKey + '/' + photo.id,
        creator: { '@type': 'Person', name: 'Dmitry Shestakov', url: 'https://photo.dimazvali.com/about' },
        copyrightHolder: { '@type': 'Person', name: 'Dmitry Shestakov' },
        copyrightYear: photo.date ? photo.date.match(/\d{4}/) && photo.date.match(/\d{4}/)[0] : null,
        acquireLicensePage: 'https://photo.dimazvali.com/' + countryKey + '/' + seriesKey + '/' + photo.id + '?inquiry=license',
      }
      if (photo.desc) _ld.description = photo.desc
      if (photo.coords) _ld.locationCreated = { '@type': 'Place', geo: { '@type': 'GeoCoordinates', latitude: photo.coords.lat, longitude: photo.coords.lng }, name: countryLabel }
      if (photo.altitude) _ld.altitude = photo.altitude
      if (photo.tags && photo.tags.length) _ld.keywords = photo.tags.map(function(t){ return allTags[t] ? allTags[t].label : t }).join(', ')
      Object.keys(_ld).forEach(function(k){ if (_ld[k] == null) delete _ld[k] })
    script(type='application/ld+json')!= JSON.stringify(_ld)

block content
  .photo-page
    .photo-page-back
      a(href=isShoot ? `/shoot/${shootSlug}` : `/${countryKey}/${seriesKey}`) ← #{isShoot ? (backLabel || '').toUpperCase() : seriesLabel.toUpperCase()}
      if isAdmin && !isShoot
        .admin-bar
          a.admin-bar-btn(href=`/admin/${countryKey}/${seriesKey}/${photo.id}/edit`) ✎ редактировать
          a.admin-bar-btn(href=`/admin/${countryKey}/${seriesKey}/upload`) + фото
    .photo-page-image
      .photo-page-bg(style=`background-image: url(${photo.urls ? photo.urls.full : '/images/photo/' + countryKey + '/' + seriesKey + '/' + photo.file})`)
      .photo-image-wrap
        .photo-type-badge(title=photo.type||'copter')
          +typeIcon(photo.type||'copter')
        if photo.annotations && photo.annotations.length
          each a, idx in photo.annotations
            button.photo-annot(type='button' data-x=a.x data-y=a.y data-text=a.text)= idx + 1
        img(
          src=photo.urls ? photo.urls.full : `/images/photo/${countryKey}/${seriesKey}/${photo.file}`
          alt=photo.title
          onerror="this.style.background='#1e1e1e';this.removeAttribute('src')"
        )
    .photo-page-info
      .photo-page-meta
        h1.photo-page-title= photo.title
        .photo-page-loc
          if isShoot
            | #{(backLabel || '').toUpperCase()}#{photo.date ? ' · ' + photo.date : ''}
          else
            | #{countryLabel.toUpperCase()} · #{seriesLabel.toUpperCase()}#{photo.date ? ' · ' + photo.date : ''}
      .photo-page-nav
        if prev
          a.nav-btn(href=isShoot ? `/shoot/${shootSlug}/${prev.id}` : `/${countryKey}/${seriesKey}/${prev.id}` data-dir='prev') ← ПРЕД.
        if next
          a.nav-btn(href=isShoot ? `/shoot/${shootSlug}/${next.id}` : `/${countryKey}/${seriesKey}/${next.id}` data-dir='next') СЛЕД. →
    if photo.desc
      p.photo-page-desc= photo.desc
    if photo.annotations && photo.annotations.length
      .photo-annot-list
        each a, i in photo.annotations
          .photo-annot-item
            span.photo-annot-num= i + 1
            span.photo-annot-item-text= a.text
    if !isShoot && photo.tags && photo.tags.length
      .photo-tags
        each tag in photo.tags
          a.photo-tag(href=`/tag/${tag}`)= allTags[tag] ? allTags[tag].label.toUpperCase() : tag.toUpperCase()
    .photo-actions
      button.action-btn(onclick='sharePhoto()') ПОДЕЛИТЬСЯ
      if photo.instagram
        a.action-btn(href=photo.instagram target='_blank' rel='noopener') INSTAGRAM
    if !isShoot
      .photo-inquiry
        - var activeTab = inquiryStatus ? 'inquiry' : 'review'
        .inquiry-tabs
          button.inquiry-tab(type='button' data-tab='review' class=(activeTab==='review' ? 'is-active' : '')) ОТЗЫВ
          button.inquiry-tab(type='button' data-tab='inquiry' class=(activeTab==='inquiry' ? 'is-active' : '')) ЗАЯВКА
        .inquiry-tab-panel(data-panel='review' style=(activeTab==='review' ? '' : 'display:none'))
          if reviewStatus === 'ok'
            p.inquiry-success ✓ СПАСИБО ЗА ОТЗЫВ!
          else
            form.inquiry-form(method='POST' action=`/${countryKey}/${seriesKey}/${photo.id}/review`)
              input.inquiry-input(type='text' name='name' placeholder='ИМЯ (НЕОБЯЗАТЕЛЬНО)' autocomplete='name')
              textarea.inquiry-input.inquiry-textarea(name='text' placeholder='ТЕКСТ ОТЗЫВА' required rows='4')
              button.inquiry-submit(type='submit') ОТПРАВИТЬ →
        .inquiry-tab-panel(data-panel='inquiry' style=(activeTab==='inquiry' ? '' : 'display:none'))
          if inquiryStatus === 'ok'
            p.inquiry-success ✓ ОТПРАВЛЕНО — ОТВЕЧУ В ТЕЧЕНИЕ 24 ЧАСОВ
          else
            if inquiryStatus === 'err'
              p.inquiry-error ✗ ПРОВЕРЬТЕ ИМЯ И EMAIL
            form.inquiry-form(method='POST' action=`/${countryKey}/${seriesKey}/${photo.id}/inquiry`)
              .inquiry-type
                each opt in [['print','ОТПЕЧАТОК'],['license','ЛИЦЕНЗИЯ'],['other','ВОПРОС']]
                  label.inquiry-radio
                    input(type='radio' name='type' value=opt[0] checked=opt[0]==='print')
                    span= opt[1]
              input.inquiry-input(type='text' name='name' placeholder='ИМЯ' required autocomplete='name')
              input.inquiry-input(type='email' name='email' placeholder='EMAIL' required autocomplete='email')
              textarea.inquiry-input.inquiry-textarea(name='message' placeholder='СООБЩЕНИЕ (НЕОБЯЗАТЕЛЬНО)' rows='3')
              button.inquiry-submit(type='submit') ОТПРАВИТЬ →

    .annot-popup#annot-popup
      button.annot-popup-close#annot-popup-close ×
      p.annot-popup-text#annot-popup-text

    if !isShoot && related && related.length
      .related
        .related-label ЕЩЁ ИЗ #{countryLabel.toUpperCase()}
        .related-strip
          each r in related
            a.related-thumb(href=`/${r.countryKey}/${r.seriesKey}/${r.id}` title=r.title)
              img(src=r.urls.preview alt=r.title loading='lazy' onerror="this.closest('.related-thumb').style.display='none'")

  script.
    (function() {
      var popup = document.getElementById('annot-popup');
      if (!popup) return;
      var popupText = document.getElementById('annot-popup-text');
      var closeBtn = document.getElementById('annot-popup-close');
      var annots = document.querySelectorAll('.photo-image-wrap .photo-annot');
      if (!annots.length) return;

      // object-fit:contain letterboxing compensation:
      // actual rendered image area inside the element may have empty margins
      var pageImg = document.querySelector('.photo-image-wrap img');
      function repositionAnnots() {
        if (!pageImg || !pageImg.naturalWidth) return;
        var W = pageImg.clientWidth;
        var H = pageImg.clientHeight;
        var scale = Math.min(W / pageImg.naturalWidth, H / pageImg.naturalHeight);
        var rW = pageImg.naturalWidth * scale;
        var rH = pageImg.naturalHeight * scale;
        var rL = (W - rW) / 2;
        var rT = (H - rH) / 2;
        annots.forEach(function(btn) {
          btn.style.left = (rL + rW * parseFloat(btn.dataset.x) / 100) + 'px';
          btn.style.top  = (rT + rH * parseFloat(btn.dataset.y) / 100) + 'px';
        });
      }
      if (pageImg) {
        if (pageImg.complete && pageImg.naturalWidth) repositionAnnots();
        else pageImg.addEventListener('load', repositionAnnots);
        window.addEventListener('resize', repositionAnnots);
      }

      annots.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          popupText.textContent = btn.dataset.text;
          var rect = btn.getBoundingClientRect();
          var popW = 240;
          var top = rect.bottom + 10;
          var left = rect.left + rect.width / 2 - popW / 2;
          left = Math.max(10, Math.min(window.innerWidth - popW - 10, left));
          if (top + 120 > window.innerHeight) top = rect.top - 130;
          if (top < 10) top = 10;
          popup.style.top = top + 'px';
          popup.style.left = left + 'px';
          popup.style.display = 'block';
        });
      });

      closeBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        popup.style.display = 'none';
      });

      document.addEventListener('click', function() { popup.style.display = 'none'; });
      popup.addEventListener('click', function(e) { e.stopPropagation(); });
    }());

    // ── Inquiry/review tabs ──
    document.querySelectorAll('.inquiry-tab').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tab = btn.dataset.tab;
        document.querySelectorAll('.inquiry-tab').forEach(function(b) {
          b.classList.toggle('is-active', b.dataset.tab === tab);
        });
        document.querySelectorAll('.inquiry-tab-panel').forEach(function(p) {
          p.style.display = p.dataset.panel === tab ? '' : 'none';
        });
      });
    });
