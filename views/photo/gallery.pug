extends layout
include mixins

block content
  if isShoot
    .shoot-crumb
      
  .gallery-header
    if isShoot
      span.gallery-label 
        a(href='/shoot') все съемки
      span.gallery-label #{shootLabel.toUpperCase()} · #{photos.length} фото
      .gallery-header-right
        a.gallery-download(href=`/shoot/${shootSlug}/download`) ↓ СКАЧАТЬ
        button.gallery-shuffle(onclick='shuffleMasonry()') ↺ ШАФЛ
    else if activeCountry && activeSeries
      - const country = data[activeCountry]
      - const series = country.series[activeSeries]
      span.gallery-label #{country.label.toUpperCase()} · #{series.label.toUpperCase()} · #{photos.length} фото
      .gallery-header-right
        button.gallery-shuffle(onclick='shuffleMasonry()') ↺ ШАФЛ
        if isAdmin
          a.admin-bar-btn(href=`/admin/${activeCountry}/${activeSeries}/upload`) + фото
          a.admin-bar-btn(href=`/admin/${activeCountry}/${activeSeries}/edit`) ✎ серия
    else if activeCountry
      - const country = data[activeCountry]
      span.gallery-label #{country.label.toUpperCase()} · #{photos.length} фото
      .gallery-header-right
        button.gallery-shuffle(onclick='shuffleMasonry()') ↺ ШАФЛ
    else
      span.gallery-label ВСЕ РАБОТЫ · #{photos.length} фото
  if isShoot
    .shoot-collections#shoot-collections(style='display:none')
      span.gallery-label ВАШИ ПОДБОРКИ
      .shoot-collections-list#shoot-collections-list
  -
    var _types = photos.reduce(function(s,p){ s.add(p.type||'copter'); return s; }, new Set());
    var _showFilter = _types.size > 1;
  if !isShoot && activeTags && activeTags.length
    .gallery-tags
      each tag in activeTags
        a.gallery-tag(href=`/tag/${tag.key}`) #{tag.label.toUpperCase()}
  if _showFilter
    .type-filter
      each t in ['copter','camera','mobile']
        if _types.has(t)
          button.type-filter-btn(data-type=t title=t)
            +typeIcon(t)
  .masonry
    each photo in photos
      a.photo-card(
        href=isShoot ? `/shoot/${shootSlug}/${photo.id}` : `/${photo.countryKey}/${photo.seriesKey}/${photo.id}`
        data-type=photo.type||'copter'
        data-photo-id=photo.id
      )
        if isShoot
          span.photo-select
            span.photo-select-box
        img(
          src=photo.urls ? photo.urls.preview : `/images/photo/${photo.countryKey}/${photo.seriesKey}/${photo.file}`
          srcset=photo.urls ? `${photo.urls.thumb || photo.urls.preview} 400w, ${photo.urls.preview} 800w` : undefined
          sizes=photo.urls ? '(max-width: 640px) calc(50vw - 12px), 400px' : undefined
          alt=photo.title
          loading='lazy'
          style=photo.width && photo.height ? `aspect-ratio:${photo.width}/${photo.height}` : undefined
          onerror="this.style.background='#1e1e1e';this.removeAttribute('src')"
        )
        .photo-overlay
          span.photo-title= photo.title
          if photo.date
            span.photo-date= photo.date

  if isShoot && otherShoots && otherShoots.length
    .gallery-header
      span.gallery-label ДРУГИЕ СЪЁМКИ
    .shoot-related
      each other in otherShoots
        - var cover = other.photos[0]
        a.shoot-related-card(href=`/shoot/${other.key}`)
          if cover
            img(
              src=cover.urls ? cover.urls.preview : undefined
              srcset=cover.urls ? `${cover.urls.thumb || cover.urls.preview} 400w, ${cover.urls.preview} 800w` : undefined
              sizes='(max-width: 640px) calc(50vw - 12px), 240px'
              alt=other.label
              loading='lazy'
              onerror="this.style.background='#1e1e1e';this.removeAttribute('src')"
            )
          .photo-overlay
            span.photo-title= other.label.toUpperCase()
            span.photo-date= `${other.photos.length} фото`

  if isShoot
    .selection-popup#intro-popup
      .selection-popup-inner
        p.intro-popup-text Привет! Кажется, мы еще не знакомы. Если вы здесь по делу, присмотритесь к картинкам: вы можете отметить нужные вам галочками — и сохранить созданную подборку. Я получу об этом уведомление.
        .selection-popup-actions
          button#intro-popup-close(type='button') ПОНЯТНО

    .selection-bar#selection-bar
      span#selection-count
      .selection-bar-actions
        button#selection-clear(type='button') ОЧИСТИТЬ
        button#selection-save(type='button') СОХРАНИТЬ ПОДБОРКУ

    .selection-popup#selection-popup
      .selection-popup-inner
        .selection-popup-form#selection-popup-form
          span.selection-popup-title НАЗВАНИЕ ПОДБОРКИ
          input#selection-name-input(type='text' placeholder='например: на ретушь' maxlength='200')
          p#selection-popup-msg
          .selection-popup-actions
            button#selection-popup-cancel(type='button') ОТМЕНА
            button#selection-popup-submit(type='button') СОХРАНИТЬ
        .selection-popup-success#selection-popup-success(style='display:none')
          p.selection-popup-success-text Спасибо! Подборка сохранена и отправлена автору.
          .selection-popup-actions
            button#selection-popup-close(type='button') ОК

  if isShoot
    script.
      (function() {
        var introKey = 'photoShootIntroSeen';
        var introPopup = document.getElementById('intro-popup');
        var introClose = document.getElementById('intro-popup-close');
        if (introPopup) {
          var seen = true;
          try { seen = !!localStorage.getItem(introKey); } catch (e) {}
          if (!seen) introPopup.classList.add('is-open');
          function dismissIntro() {
            introPopup.classList.remove('is-open');
            try { localStorage.setItem(introKey, '1'); } catch (e) {}
          }
          if (introClose) introClose.addEventListener('click', dismissIntro);
          introPopup.addEventListener('click', function(e) { if (e.target === introPopup) dismissIntro(); });
        }
      }());

  if isShoot
    script.
      (function() {
        var saveUrl = '/shoot/' + !{JSON.stringify(shootSlug)} + '/collections';
        var storageKey = 'shootSelection:' + !{JSON.stringify(shootSlug)};
        var savedKey = 'shootCollections:' + !{JSON.stringify(shootSlug)};
        var selected = {};

        function loadSavedCollections() {
          try {
            var raw = localStorage.getItem(savedKey);
            return raw ? JSON.parse(raw) : [];
          } catch (e) { return []; }
        }
        function saveSavedCollections(list) {
          try { localStorage.setItem(savedKey, JSON.stringify(list.slice(-20))); } catch (e) {}
        }

        function loadStored() {
          try {
            var raw = sessionStorage.getItem(storageKey);
            return raw ? JSON.parse(raw) : {};
          } catch (e) { return {}; }
        }
        function saveStored() {
          try { sessionStorage.setItem(storageKey, JSON.stringify(selected)); } catch (e) {}
        }

        var bar      = document.getElementById('selection-bar');
        var countEl  = document.getElementById('selection-count');
        var popup    = document.getElementById('selection-popup');
        var formView = document.getElementById('selection-popup-form');
        var successView = document.getElementById('selection-popup-success');
        var nameInput = document.getElementById('selection-name-input');
        var msgEl    = document.getElementById('selection-popup-msg');
        var saveBtn  = document.getElementById('selection-save');
        var clearBtn = document.getElementById('selection-clear');
        var cancelBtn = document.getElementById('selection-popup-cancel');
        var submitBtn = document.getElementById('selection-popup-submit');
        var closeBtn = document.getElementById('selection-popup-close');

        function closePopup() {
          popup.classList.remove('is-open');
          formView.style.display = '';
          successView.style.display = 'none';
        }

        function selectedIds() {
          return Object.keys(selected).filter(function(id) { return selected[id]; });
        }

        function updateBar() {
          var ids = selectedIds();
          if (bar) bar.classList.toggle('is-open', ids.length > 0);
          if (countEl) countEl.textContent = 'ВЫБРАНО: ' + ids.length;
        }

        function clearSelection() {
          selected = {};
          saveStored();
          document.querySelectorAll('.photo-select.is-checked').forEach(function(el) { el.classList.remove('is-checked'); });
          document.querySelectorAll('.photo-card.is-selected').forEach(function(el) { el.classList.remove('is-selected'); });
          updateBar();
        }

        function applySelection(ids) {
          clearSelection();
          document.querySelectorAll('.photo-card[data-photo-id]').forEach(function(card) {
            var id = card.dataset.photoId;
            if (ids.indexOf(id) === -1) return;
            selected[id] = true;
            card.classList.add('is-selected');
            var box = card.querySelector('.photo-select');
            if (box) box.classList.add('is-checked');
          });
          saveStored();
          updateBar();
        }

        var collectionsWrap = document.getElementById('shoot-collections');
        var collectionsList = document.getElementById('shoot-collections-list');

        function renderSavedCollections() {
          if (!collectionsWrap || !collectionsList) return;
          var list = loadSavedCollections();
          if (!list.length) { collectionsWrap.style.display = 'none'; return; }
          collectionsList.innerHTML = '';
          list.forEach(function(c) {
            var chip = document.createElement('button');
            chip.type = 'button';
            chip.className = 'shoot-collection-chip';
            chip.textContent = c.name + ' · ' + c.count + ' фото';
            chip.addEventListener('click', function() { applySelection(c.photoIds || []); });
            collectionsList.appendChild(chip);
          });
          collectionsWrap.style.display = '';
        }
        renderSavedCollections();

        document.querySelectorAll('.photo-select').forEach(function(el) {
          el.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var card = el.closest('.photo-card');
            var id = card.dataset.photoId;
            selected[id] = !selected[id];
            el.classList.toggle('is-checked', !!selected[id]);
            card.classList.toggle('is-selected', !!selected[id]);
            saveStored();
            updateBar();
          });
        });

        // restore selection saved before navigating away (e.g. to a photo detail page)
        (function restore() {
          var stored = loadStored();
          var restored = false;
          document.querySelectorAll('.photo-card[data-photo-id]').forEach(function(card) {
            var id = card.dataset.photoId;
            if (!stored[id]) return;
            selected[id] = true;
            restored = true;
            card.classList.add('is-selected');
            var box = card.querySelector('.photo-select');
            if (box) box.classList.add('is-checked');
          });
          if (restored) { saveStored(); updateBar(); }
        }());

        if (clearBtn) clearBtn.addEventListener('click', clearSelection);

        if (saveBtn) saveBtn.addEventListener('click', function() {
          nameInput.value = '';
          msgEl.textContent = '';
          formView.style.display = '';
          successView.style.display = 'none';
          popup.classList.add('is-open');
          nameInput.focus();
        });

        if (cancelBtn) cancelBtn.addEventListener('click', closePopup);
        if (closeBtn) closeBtn.addEventListener('click', closePopup);
        if (popup) popup.addEventListener('click', function(e) { if (e.target === popup) closePopup(); });

        if (submitBtn) submitBtn.addEventListener('click', function() {
          var name = nameInput.value.trim();
          if (!name) { msgEl.textContent = 'Введите название'; return; }
          var ids = selectedIds();
          if (!ids.length) { popup.classList.remove('is-open'); return; }

          submitBtn.disabled = true;
          msgEl.textContent = '';
          fetch(saveUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name, photoIds: ids }),
          })
            .then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); })
            .then(function(res) {
              submitBtn.disabled = false;
              if (!res.ok) { msgEl.textContent = (res.data && res.data.error) || 'Ошибка сохранения'; return; }
              var savedList = loadSavedCollections();
              savedList.push({ id: res.data.id, name: name, count: ids.length, photoIds: ids, createdAt: Date.now() });
              saveSavedCollections(savedList);
              renderSavedCollections();
              clearSelection();
              formView.style.display = 'none';
              successView.style.display = '';
            })
            .catch(function() {
              submitBtn.disabled = false;
              msgEl.textContent = 'Ошибка сети';
            });
        });
      }());

  if _showFilter
    script.
      (function() {
        var btns = document.querySelectorAll('.type-filter-btn');
        var cards = document.querySelectorAll('.photo-card[data-type]');
        var active = null;
        btns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            var t = btn.dataset.type;
            if (active === t) {
              active = null;
              btns.forEach(function(b){ b.classList.remove('active'); });
              cards.forEach(function(c){ c.removeAttribute('data-hidden'); });
            } else {
              active = t;
              btns.forEach(function(b){ b.classList.toggle('active', b.dataset.type === t); });
              cards.forEach(function(c){ c.toggleAttribute('data-hidden', c.dataset.type !== t); });
            }
          });
        });
      }());
