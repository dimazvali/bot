doctype html
html(data-theme='dark')
  head
    title= title
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(name='robots' content='noindex,nofollow')
    link(rel='stylesheet' href='/stylesheets/photo/style.css')
  body
    .shoot-password-wrap
      .shoot-password-box
        h1.shoot-password-title= label
        if error
          p.shoot-password-error ✗ НЕВЕРНЫЙ ПАРОЛЬ
        form.shoot-password-form(method='POST' action=`/shoot/${slug}/auth`)
          input.shoot-password-input(type='password' name='password' placeholder='ПАРОЛЬ' autofocus required)
          button.shoot-password-btn(type='submit') →
