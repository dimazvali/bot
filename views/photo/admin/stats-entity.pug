doctype html
html(data-theme='dark')
  head
    title= title
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    link(rel='stylesheet' href='/stylesheets/photo/style.css')
    style.
      .stats-entity-header { display: flex; flex-direction: column; gap: 4px; }
      .stats-entity-type { font-size: 11px; letter-spacing: .1em; color: #666; }
      .stats-entity-name { font-size: 16px; font-weight: 600; }
      .stats-entity-name a { color: inherit; text-decoration: none; border-bottom: 1px solid #444; }
      .stats-entity-name a:hover { border-color: #aaa; }
      .stats-summary { display: flex; gap: 24px; margin-top: 12px; }
      .stats-summary-item { display: flex; flex-direction: column; gap: 2px; }
      .stats-summary-val { font-size: 22px; font-weight: 600; }
      .stats-summary-key { font-size: 11px; color: #666; letter-spacing: .07em; }
  body
    .admin-wrap
      .admin-header
        a.admin-back(href=`/admin/stats?days=${days}`) ← статистика
        span.admin-logo СТРАНИЦА
        .stats-period
          a.admin-link(href=`?type=${entityType}&id=${encodeURIComponent(entityId)}&days=7` class=days===7?'active':'') 7Д
          a.admin-link(href=`?type=${entityType}&id=${encodeURIComponent(entityId)}&days=30` class=days===30?'active':'') 30Д
          a.admin-link(href=`?type=${entityType}&id=${encodeURIComponent(entityId)}&days=90` class=days===90?'active':'') 90Д

      if error
        .admin-section
          p.admin-hint= error

      else
        .admin-section
          .stats-entity-header
            span.stats-entity-type= (entityType || '').toUpperCase()
            .stats-entity-name
              if entityInfo.url
                a(href=entityInfo.url target='_blank' rel='noopener')= entityInfo.label
              else
                | #{entityInfo.label}
          .stats-summary
            .stats-summary-item
              span.stats-summary-val= total
              span.stats-summary-key ПРОСМОТРОВ · #{days} ДНЕЙ
            each count, type in byDevice
              if count
                .stats-summary-item
                  span.stats-summary-val= count
                  span.stats-summary-key= type.toUpperCase()

        .admin-section
          h2.admin-title ПРОСМОТРЫ ПО ДНЯМ
          .stats-chart
            each item in allDays
              .stats-bar-row
                span.stats-day= item.day.slice(5)
                .stats-bar-wrap
                  if item.count
                    .stats-bar(style=`width:${Math.round(item.count/maxCount*100)}%`)
                span.stats-count= item.count || ''
