doctype html
html(data-theme='dark')
  head
    title= title
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    - var _desc = desc || 'Аэрофотосъёмка — Дмитрий Шестаков'
    meta(name='description' content=_desc)
    if noindex
      meta(name='robots' content='noindex,nofollow')
    if keywords
      meta(name='keywords' content=keywords)
    meta(property='og:title' content=title)
    meta(property='og:description' content=_desc)
    meta(property='og:type' content='website')
    meta(property='og:site_name' content='photo.dimazvali.com')
    if ogImage
      meta(property='og:image' content=ogImage)
    if ogUrl
      meta(property='og:url' content=ogUrl)
      link(rel='canonical' href=ogUrl)
    meta(name='twitter:card' content='summary_large_image')
    if breadcrumbs && breadcrumbs.length
      - var _ldItems = [{"@type":"ListItem","position":1,"name":"Главная","item":"https://photo.dimazvali.com/"}].concat(breadcrumbs.map(function(b,i){return{"@type":"ListItem","position":i+2,"name":b.name,"item":b.url};}))
      script(type='application/ld+json')!= JSON.stringify({"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":_ldItems})
    if googleClientId
      meta(name='google-client-id' content=googleClientId)
    block head
    link(rel='icon' href='/images/photo/ds_georgian.ico')
    link(rel='stylesheet' href='/stylesheets/photo/style.css')
    script(async src='https://www.googletagmanager.com/gtag/js?id=G-LDMN4XFB42')
    script.
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LDMN4XFB42');
  body(data-series-url=seriesUrl || '')
    header.mobile-header
      button.burger#burger ☰
      a.mobile-logo(href='https://dimazvali.com') dimazvali.com
      button.theme-toggle(onclick='toggleTheme()' title='Тема') ◐
    .mobile-colors
      each family, key in colorFamilies
        a.color-dot(
          href=`/color/${key}`
          title=family.label
          style=`background:${family.hex}`
          class=activeColorFamily===key?'active':''
        )
    .site
      aside.sidebar#sidebar
        .sidebar-logo
          a(href='https://dimazvali.com') dimazvali.com
          span Дмитрий Шестаков
        nav.sidebar-nav
          each country, countryKey in data
            if !country.archived
              - var seriesOrder = country.seriesOrder || Object.keys(country.series)
              a.nav-country(
                href=`/${countryKey}`
                class=activeCountry === countryKey ? 'open' : ''
              )
                span.arrow= activeCountry === countryKey ? '▾' : '▸'
                | &nbsp;
                = country.label.toUpperCase()
              if activeCountry === countryKey
                each seriesKey in seriesOrder
                  - var series = country.series[seriesKey]
                  if series && !series.archived
                    a.nav-series(
                      href=`/${countryKey}/${seriesKey}`
                      class=activeSeries === seriesKey ? 'active' : ''
                    ) #{series.label}
        .sidebar-colors
          each family, key in colorFamilies
            a.color-dot(
              href=`/color/${key}`
              title=family.label
              style=`background:${family.hex}`
              class=activeColorFamily===key?'active':''
            )
        .sidebar-footer
          .sidebar-contacts
            a(href='mailto:dimazvali@gmail.com') dimazvali@gmail.com
            a(href='https://t.me/dimazvali' target='_blank' rel='noopener') @dimazvali
            a(href='https://instagram.com/dimazvali2' target='_blank' rel='noopener') @dimazvali2
          if photoUser && photoUser.subscribed
            p.subscribe-msg ✓ вы подписаны (почта)
            button.subscribe-unsub#unsubscribe-google-btn(type='button') отписаться
          else
            .subscribe-wrap
              p.subscribe-msg#subscribe-msg(style='display:none')
              button.subscribe-toggle#subscribe-toggle(type='button') подписаться →
              .subscribe-popup#subscribe-popup(style='display:none')
                button.subscribe-option#subscribe-email-btn(type='button') по почте
                a.subscribe-option(href='https://t.me/dimazvalibot?start=photo_sub' target='_blank' rel='noopener') в телеграм
          .sidebar-footer-bottom
            //- a(href='/about') О СЕБЕ
            button.theme-toggle(onclick='toggleTheme()' title='Переключить тему') ◐
      .sidebar-overlay#sidebar-overlay
      main.main
        block content
    script(src='/javascripts/photo/main.js')
    if googleClientId
      script(src='https://accounts.google.com/gsi/client' async defer)
      script(src='/javascripts/photo/subscribe.js' defer)
