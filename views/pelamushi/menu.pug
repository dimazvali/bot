extends layout
include includes/hero
include includes/page-nav

block head
  -
    function buildMenuLd(menu, grouped, uncategorized, lang) {
      const clean = (s) => s ? String(s).trim() : undefined;
      const makeItem = (item) => {
        const o = { '@type': 'MenuItem', name: clean(item['name_' + lang]) };
        const desc = clean(item['desc_' + lang]);
        if (desc) o.description = desc;
        if (item.price) o.offers = { '@type': 'Offer', price: String(item.price), priceCurrency: 'GEL', availability: 'https://schema.org/InStock' };
        if (item.photo_url && !item.photo_url.includes('placehold.co')) o.image = item.photo_url;
        return o;
      };
      const ld = {
        '@context': 'https://schema.org',
        '@type': 'Menu',
        name: clean(menu['name_' + lang]),
        url: 'https://pelamushi.ge/' + lang + '/menu/' + menu.slug,
        hasMenuSection: [],
      };
      const desc = clean(menu['desc_' + lang]);
      if (desc) ld.description = desc;
      grouped.filter(c => c.items.length).forEach(cat => {
        const section = { '@type': 'MenuSection', name: clean(cat['name_' + lang]), hasMenuItem: cat.items.map(makeItem) };
        const sd = clean(cat['desc_' + lang]);
        if (sd) section.description = sd;
        ld.hasMenuSection.push(section);
      });
      if (uncategorized.length) {
        ld.hasMenuSection.push({ '@type': 'MenuSection', name: 'Other', hasMenuItem: uncategorized.map(makeItem) });
      }
      return ld;
    }
  script(type='application/ld+json') !{JSON.stringify(buildMenuLd(menu, grouped, uncategorized, lang))}

mixin menuItem(item)
  .menu-item(data-id=item.id data-name=item['name_' + lang] data-price=item.price)
    .item-photo
      img(src=item.photo_url || '/images/pelamushi/item-placeholder.svg' alt=item['name_' + lang])
    .item-body
      .item-name #{item['name_' + lang]}
      if item['desc_' + lang]
        .item-desc #{item['desc_' + lang]}
      .item-footer
        .item-price #{item.price} ₾
        .item-qty
          button.qty-btn.qty-dec(type='button') −
          span.qty-val 0
          button.qty-btn.qty-inc(type='button') +
      if item.tags && item.tags.length
        .item-tags
          each tag in item.tags
            span.tag #{tag}

block scripts
  script.
    document.addEventListener('DOMContentLoaded', () => {
      const siteNav = document.querySelector('.site-nav');
      const pageNav = document.querySelector('.page-nav');
      function updateHeights() {
        if (siteNav) document.documentElement.style.setProperty('--nav-h', siteNav.offsetHeight + 'px');
        if (pageNav) document.documentElement.style.setProperty('--page-nav-h', pageNav.offsetHeight + 'px');
      }
      updateHeights();
      window.addEventListener('resize', updateHeights);

      const sections = Array.from(document.querySelectorAll('.menu-category[id]'));
      const navBtns  = Array.from(document.querySelectorAll('.page-nav-btn'));
      if (!sections.length || !navBtns.length) return;

      const label = pageNav && pageNav.querySelector('.page-nav-label');
      function setActive(id) {
        navBtns.forEach(btn => btn.classList.toggle('active', btn.getAttribute('href') === '#' + id));
        const active = pageNav && pageNav.querySelector('.page-nav-btn.active');
        if (active) {
          active.scrollIntoView({ inline: 'nearest', block: 'nearest' });
          if (label) label.textContent = active.textContent;
        }
      }

      const observer = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) setActive(e.target.id); });
      }, { rootMargin: '-15% 0px -65% 0px' });
      sections.forEach(s => observer.observe(s));

      navBtns.forEach(btn => {
        btn.addEventListener('click', e => {
          e.preventDefault();
          const target = document.querySelector(btn.getAttribute('href'));
          if (!target) return;
          const offset = (siteNav ? siteNav.offsetHeight : 64) + (pageNav ? pageNav.offsetHeight : 48) + 16;
          window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - offset, behavior: 'smooth' });
        });
      });
    });
  script(src=`/javascripts/pelamushi/order.js?v=${v}`)

block content
  - const navItems = grouped.filter(c => c.items.length).map(c => ({ href: '#cat-' + c.id, label: c['name_' + lang] }))
  - if (uncategorized.length) navItems.push({ href: '#cat-other', label: t.menu.other })

  +hero(menu.cover_url, menu.icon_url)
    h1 #{menu['name_' + lang]}
    if menu['desc_' + lang]
      p.hero-subtitle #{menu['desc_' + lang]}

  +pageNav(navItems)

  .container.section
    each cat in grouped
      if cat.items.length
        .menu-category(id='cat-' + cat.id)
          .menu-category-header
            h3 #{cat['name_' + lang]}
            if cat['desc_' + lang]
              span.menu-category-desc #{cat['desc_' + lang]}
          .menu-items-grid
            each item in cat.items
              +menuItem(item)

    if uncategorized.length
      .menu-category#cat-other
        .menu-items-grid
          each item in uncategorized
            +menuItem(item)

  #order-bar.order-bar.hidden
    .order-bar-inner
      .order-bar-info
        span.order-bar-count
        span.order-bar-total
      span.order-bar-cta

  #order-popup.order-popup.hidden
    .order-popup-overlay
    .order-popup-box
      button.order-popup-close(type='button') ×
      h2.order-popup-title
      .order-popup-items
      .order-popup-footer
        span.order-popup-sum
        button.order-popup-clear(type='button')
