extends layout
include includes/page-nav
include includes/hero

block content
  +hero(about.hero_url, about.icon_url)
    h1 #{t.about.title}

  -
    var navItems = [];
    if (about['mission_' + lang]) navItems.push({ label: t.about.nav_desc,     href: '#about-desc' });
    if (team.length)              navItems.push({ label: t.about.nav_team,      href: '#about-team' });
    if (gallery.length)           navItems.push({ label: t.about.nav_gallery,   href: '#about-gallery' });
    if (mentions && mentions.length) navItems.push({ label: t.about.nav_mentions, href: '#about-mentions' });
  +pageNav(navItems, t.about.title)

  if about['mission_' + lang]
    .container.section#about-desc
      .bar-text!= about['mission_' + lang]

  if team.length
    .container.section#about-team
      h2(style='margin-bottom:1.5rem') #{t.about.team}
      .team-grid
        each member in team
          .team-card
            .avatar
              img(src=member.photo_url alt=member.name)
            .name #{member.name}
            .role #{member['role_' + lang]}

  if gallery.length
    .container.section#about-gallery
      h2(style='margin-bottom:1.5rem') #{t.about.interior}
      .masonry-grid
        each photo in gallery
          .masonry-item
            img.gallery-photo(src=photo.photo_url alt=(photo['caption_' + lang] || '') data-caption=(photo['caption_' + lang] || ''))

  if mentions && mentions.length
    .container.section#about-mentions
      h2(style='margin-bottom:1.5rem') #{t.about.mentions}
      .mentions-grid
        each m in mentions
          a.mention-card(href=m.url target='_blank' rel='nofollow noopener')
            .mention-logo
              img(src=m.logo_url alt=m.name)
            blockquote.mention-quote #{m.quote}
            .mention-source — #{m.name}

  include includes/lightbox
