extends layout
include includes/hero

block content
  +hero(site && (site.menu_hero_url || site.hero_url), site && site.menu_icon_url)
    h1 #{t.menu.title}

  .container.section
    .menu-cards
      each m in menus
        a.menu-card(href=`/${lang}/menu/${m.slug}`)
          if m.cover_url
            .menu-card-photo
              img(src=m.cover_url alt=m['name_' + lang])
          .menu-card-body
            if m.type === 'event'
              span.event-badge #{t.news.event_badge}
            h3 #{m['name_' + lang]}
            if m['desc_' + lang]
              p #{m['desc_' + lang]}
