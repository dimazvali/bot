extends layout

block content
  if saved
    .alert.alert-success Статус обновлён

  .card
    .requests-header
      h2 Заявки на аренду (#{requests.length}#{statusFilter ? ' — фильтр: ' + {new:'Новые',working:'В работе',cancelled:'Отмена',done:'Выполнено'}[statusFilter] : ''})
      .status-filter
        a.status-pill(href='/admin/rental/requests' class=!statusFilter ? 'active' : '') Все
        a.status-pill.status-new(href='/admin/rental/requests?status=new' class=statusFilter==='new' ? 'active' : '') Новые
        a.status-pill.status-working(href='/admin/rental/requests?status=working' class=statusFilter==='working' ? 'active' : '') В работе
        a.status-pill.status-cancelled(href='/admin/rental/requests?status=cancelled' class=statusFilter==='cancelled' ? 'active' : '') Отмена
        a.status-pill.status-done(href='/admin/rental/requests?status=done' class=statusFilter==='done' ? 'active' : '') Выполнено

    if requests.length
      table.table.table-responsive
        thead
          tr
            th Дата
            th Имя
            th Контакт
            th Дата брони
            th Время
            th Сообщение
            th UTM
            th Статус
        tbody
          each r in requests
            tr
              td(data-label='Дата' style='white-space:nowrap;font-size:.8rem;color:#999')
                = r.created_at ? r.created_at.toDate().toLocaleDateString('ru-RU') : '—'
              td(data-label='Имя')
                a(href=`/admin/rental/requests/${r.id}`)= r.name
              td(data-label='Контакт') #{r.contact}
              td(data-label='Дата брони' style='white-space:nowrap') #{r.date || '—'}
              td(data-label='Время')
                case r.time_slot
                  when 'morning'
                    | Утро
                  when 'afternoon'
                    | День
                  when 'evening'
                    | Вечер
                  default
                    | #{r.time_slot || '—'}
              td(data-label='Сообщение' style='font-size:.82rem;color:#666') #{r.message || '—'}
              td(data-label='UTM' style='font-size:.8rem;color:#999') #{r.utm_source || '—'}
              td(data-label='Статус')
                form(action=`/admin/rental/requests/${r.id}/status` method='POST')
                  select.status-select(name='status' onchange='this.form.submit()')
                    option(value='new'       selected=r.status==='new')       Новая
                    option(value='working'   selected=r.status==='working')   В работе
                    option(value='cancelled' selected=r.status==='cancelled') Отмена
                    option(value='done'      selected=r.status==='done')      Выполнено
    else
      p(style='color:#999;font-size:.9rem') Заявок пока нет.
