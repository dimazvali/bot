extends layout

block content
  .card(style='margin-bottom:.75rem')
    a.btn.btn-secondary(href='/admin/registrations/export.csv') Скачать CSV

  .card
    h2 Регистрации
    table.table
      thead
        tr
          th Событие
          th Имя
          th Email
          th Телефон
          th Дата
      tbody
        each r in regs
          tr
            td #{newsMap[r.news_id] || r.news_id}
            td #{r.name}
            td #{r.email}
            td #{r.phone || '—'}
            td #{r.created_at ? new Date(r.created_at.toDate()).toLocaleDateString('ru-RU') : ''}
