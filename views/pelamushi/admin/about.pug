extends layout

block content
  if saved
    .alert.alert-success Сохранено

  .card
    h2 Фото подложки (главная страница)
    if about.home_hero_url
      img(src=about.home_hero_url style='width:100%;max-height:200px;object-fit:cover;border-radius:6px;margin-bottom:.75rem')
    form(action='/admin/about/home-hero' method='POST' enctype='multipart/form-data')
      .form-row
        label Заменить фото
        input(type='file' name='photo' accept='image/*')
      button.btn.btn-secondary.btn-sm(type='submit') Загрузить

  .card
    h2 Фото подложки (о нас)
    if about.hero_url
      img(src=about.hero_url style='width:100%;max-height:200px;object-fit:cover;border-radius:6px;margin-bottom:.75rem')
    form(action='/admin/about/hero' method='POST' enctype='multipart/form-data')
      .form-row
        label Заменить фото
        input(type='file' name='photo' accept='image/*')
      button.btn.btn-secondary.btn-sm(type='submit') Загрузить

  .card
    h2 Иконка
    p(style='font-size:.82rem;color:#666;margin-bottom:.75rem') Маленькое изображение над заголовком
    if about.icon_url
      img(src=about.icon_url style='max-height:80px;max-width:200px;border-radius:4px;margin-bottom:.75rem;background:#1C2E4A;padding:.5rem')
    form(action='/admin/about/icon' method='POST' enctype='multipart/form-data')
      .form-row
        label Загрузить иконку
        input(type='file' name='photo' accept='image/*')
      button.btn.btn-secondary.btn-sm(type='submit') Загрузить

  .card
    h2 Цитата
    form(action='/admin/about/quote' method='POST')
      .form-row
        label EN
        textarea(name='quote_en') #{about.quote_en}
      .form-row
        label KA
        textarea(name='quote_ka') #{about.quote_ka}
      .form-row
        label RU
        textarea(name='quote_ru') #{about.quote_ru}
      button.btn.btn-primary(type='submit') Сохранить

  .card
    h2 Текст о нас
    form(action='/admin/about/mission' method='POST')
      .form-row
        label EN
        textarea(name='mission_en') #{about.mission_en}
      .form-row
        label KA
        textarea(name='mission_ka') #{about.mission_ka}
      .form-row
        label RU
        textarea(name='mission_ru') #{about.mission_ru}
      button.btn.btn-primary(type='submit') Сохранить

  .card
    h2 Контакты и соцсети
    form(action='/admin/about/social' method='POST')
      .form-row
        label Facebook URL
        input(type='url' name='facebook_url' value=about.facebook_url placeholder='https://facebook.com/...')
      .form-row
        label Instagram URL
        input(type='url' name='instagram_url' value=about.instagram_url placeholder='https://instagram.com/...')
      .form-row
        label Google Maps URL
        input(type='url' name='maps_url' value=about.maps_url placeholder='https://maps.app.goo.gl/...')
      .form-row
        label Телефон (ссылка tel:)
        input(type='tel' name='phone' value=about.phone placeholder='+995 555 000000')
      .form-row
        label WhatsApp (только цифры, с кодом страны)
        input(type='tel' name='whatsapp' value=about.whatsapp placeholder='995555000000')
      button.btn.btn-primary(type='submit') Сохранить

  .card
    h2 Интерьер
    if gallery.length
      form(action='/admin/about/gallery/update' method='POST')
        .gallery-edit-list
          each photo, i in gallery
            .gallery-edit-row
              img(src=photo.photo_url alt='')
              .gallery-edit-fields
                input(type='hidden' name=`photos[${i}][id]` value=photo.id)
                .order-row
                  span #
                  input(type='number' name=`photos[${i}][order]` value=(photo.order !== undefined ? photo.order : i) min='0')
                input(type='text' name=`photos[${i}][caption_en]` placeholder='Подпись EN' value=(photo.caption_en || ''))
                input(type='text' name=`photos[${i}][caption_ka]` placeholder='Подпись KA' value=(photo.caption_ka || ''))
                input(type='text' name=`photos[${i}][caption_ru]` placeholder='Подпись RU' value=(photo.caption_ru || ''))
              button.btn.btn-danger.btn-sm(type='submit' formaction=`/admin/about/gallery/${photo.id}/delete` onclick='return confirm("Удалить?")') ×
        button.btn.btn-primary.btn-sm(type='submit') Сохранить порядок и подписи
    form(action='/admin/about/gallery/add' method='POST' enctype='multipart/form-data' style='margin-top:1rem')
      .form-row
        label Добавить фото
        input(type='file' name='photo' accept='image/*' multiple)
      button.btn.btn-secondary.btn-sm(type='submit') Загрузить

  .card
    h2 Команда
    table.table
      thead
        tr
          th Имя
          th Роль (EN)
          th
      tbody
        each member in team
          tr
            td #{member.name}
            td #{member.role_en}
            td(style='white-space:nowrap')
              a.btn.btn-secondary.btn-sm(href=`/admin/about/team/${member.id}`) Изменить
              |
              form(action=`/admin/about/team/${member.id}/delete` method='POST' style='display:inline')
                button.btn.btn-danger.btn-sm(type='submit' onclick='return confirm("Удалить?")') Удалить
    h3(style='margin:1.25rem 0 .75rem;font-size:.9rem;color:var(--navy)') Добавить участника
    form(action='/admin/about/team/add' method='POST' enctype='multipart/form-data')
      .form-row
        label Имя
        input(name='name')
      .form-row
        label Роль EN
        input(name='role_en')
      .form-row
        label Роль KA
        input(name='role_ka')
      .form-row
        label Роль RU
        input(name='role_ru')
      .form-row
        label Фото
        input(type='file' name='photo' accept='image/*')
      button.btn.btn-secondary.btn-sm(type='submit') Добавить

  .card
    h2 Упоминания в прессе
    if mentions && mentions.length
      table.table(style='margin-bottom:1.25rem')
        thead
          tr
            th Лого
            th Медиа
            th Цитата
            th
        tbody
          each m in mentions
            tr
              td
                if m.logo_url
                  img(src=m.logo_url style='height:32px;width:auto;object-fit:contain;background:#f5f5f5;padding:2px;border-radius:3px')
              td(style='font-weight:600') #{m.name}
              td(style='max-width:260px;font-size:.82rem;color:#666') #{(m.quote || '').substring(0, 80)}#{(m.quote || '').length > 80 ? '…' : ''}
              td(style='white-space:nowrap')
                a.btn.btn-secondary.btn-sm(href=`/admin/about/mentions/${m.id}`) Изменить
    h3(style='margin:1.25rem 0 .75rem;font-size:.9rem;color:var(--navy)') Добавить упоминание
    form(action='/admin/about/mentions/add' method='POST' enctype='multipart/form-data')
      .form-row
        label Логотип
        input(type='file' name='logo' accept='image/*')
      .form-row
        label Название медиа
        input(name='name' required)
      .form-row
        label Цитата
        textarea(name='quote' rows='3')
      .form-row
        label Ссылка
        input(type='url' name='url' placeholder='https://...')
      button.btn.btn-secondary.btn-sm(type='submit') Добавить
