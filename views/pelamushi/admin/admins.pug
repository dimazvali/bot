extends layout

block content
  if saved
    .alert.alert-success Сохранено

  if err === 'self'
    .alert.alert-error Нельзя удалить себя

  .card
    h2 Администраторы
    if admins.length
      table.table
        thead
          tr
            th Имя
            th
            th
        tbody
          each a in admins
            tr
              td
                | #{a.name}
                if a.password_hash === currentHash
                  span(style='font-size:.75rem;color:#999;margin-left:.5rem') (вы)
              td
                form(action=`/admin/admins/${a.id}/password` method='POST' style='display:flex;gap:.5rem;align-items:center')
                  input(type='password' name='password' placeholder='Новый пароль' style='padding:.25rem .5rem;font-size:.82rem;border:1px solid #ddd;border-radius:4px;width:160px')
                  button.btn.btn-secondary.btn-sm(type='submit') Изменить
              td
                if a.password_hash !== currentHash
                  form(action=`/admin/admins/${a.id}/delete` method='POST')
                    button.btn.btn-danger.btn-sm(type='submit' onclick='return confirm("Удалить администратора?")') Удалить
    else
      p(style='color:#999;font-size:.88rem') Администраторов пока нет. Добавьте ниже.

  .card
    h2 Добавить администратора
    form(action='/admin/admins/add' method='POST')
      .form-row
        label Имя
        input(name='name' placeholder='Иван Иванов')
      .form-row
        label Пароль
        input(type='password' name='password' placeholder='••••••••')
      button.btn.btn-primary(type='submit') Добавить
