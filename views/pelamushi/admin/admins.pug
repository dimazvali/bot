extends layout

block content
  if saved
    .alert.alert-success Сохранено

  if err === 'self'
    .alert.alert-error Нельзя удалить себя

  each a in admins
    .card
      .admin-card-header
        span.admin-card-name
          | #{a.name}
          if a.password_hash === currentHash
            span.admin-self-badge вы

      .admin-card-body
        .admin-card-col
          p.admin-col-label Telegram ID
          form(action=`/admin/admins/${a.id}/settings` method='POST')
            .admin-tg-row
              input(name='tg_id' value=a.tg_id || '' placeholder='числовой chat_id' style='width:160px')
              button.btn.btn-secondary.btn-sm(type='submit') Сохранить
            .admin-notif-grid
              label.notif-label
                input(type='checkbox' name='notify_rental' checked=a.notify_rental)
                span 🏠 Аренда
              label.notif-label
                input(type='checkbox' name='notify_registration' checked=a.notify_registration)
                span 📋 Регистрации
              label.notif-label
                input(type='checkbox' name='notify_menu' checked=a.notify_menu)
                span 🍽 Меню
              label.notif-label
                input(type='checkbox' name='notify_news' checked=a.notify_news)
                span 📰 Новости

        .admin-card-col
          p.admin-col-label Пароль
          form(action=`/admin/admins/${a.id}/password` method='POST' style='display:flex;gap:.5rem;align-items:center')
            input(type='password' name='password' placeholder='Новый пароль' style='width:160px')
            button.btn.btn-secondary.btn-sm(type='submit') Изменить

          if a.password_hash !== currentHash
            form(action=`/admin/admins/${a.id}/delete` method='POST' style='margin-top:.75rem')
              button.btn.btn-danger.btn-sm(type='submit' onclick='return confirm("Удалить администратора?")') Удалить

  .card
    h2 Добавить администратора
    form(action='/admin/admins/add' method='POST')
      .form-row
        label Имя
        input(name='name' placeholder='Иван Иванов')
      .form-row
        label Пароль
        input(type='password' name='password' placeholder='••••••••')
      button.btn.btn-primary(type='submit') Добавить
