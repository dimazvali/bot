extends layout

block content
  .hero
    .hero-photo
      if profile && profile.photoSizes
        picture
          source(media='(max-width:400px)' srcset=profile.photoSizes.w400)
          source(media='(max-width:800px)' srcset=profile.photoSizes.w800)
          img(src=profile.photoSizes.w1400 alt='Эка Елисеева')
      else if profile && profile.photo
        img(src=profile.photo alt='Эка Елисеева' style='width:100%;height:100%;object-fit:cover')
      else
        .hero-photo-placeholder ФОТО ЭКИ
    .hero-text
      .hero-eyebrow= lang === 'ru' ? 'Гид по Грузии · Тбилиси' : 'Georgia Guide · Tbilisi'
      .hero-name= lang === 'ru' ? 'Об Эке' : 'About Eka'
      - var bio = lang === 'ru' ? (profile && profile.bioRu) : (profile && profile.bioEn)
      if bio
        - var paragraphs = bio.split(/\n\n+/)
        each para in paragraphs
          p.about-text= para
      else
        p.about-text(style='color:#bbb')= lang === 'ru' ? 'Биография не заполнена.' : 'Bio not filled in yet.'
      .about-contacts
        if profile && profile.telegram
          a.about-contact-link(href=profile.telegram target='_blank')= 'Telegram: ' + profile.telegram.replace('https://telegram.me/', '@')
        if profile && profile.contactEmail
          a.about-contact-link(href='mailto:' + profile.contactEmail)= 'Email: ' + profile.contactEmail
        if profile && profile.instagram
          a.about-contact-link(href=profile.instagram target='_blank')= 'Instagram: ' + profile.instagram.replace('https://instagram.com/', '@').replace('https://www.instagram.com/', '@')
