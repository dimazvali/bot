extends layout

mixin tourDate(tour)
  - var d = tour.date && tour.date.toDate ? tour.date.toDate() : new Date(tour.date)
  - var months_ru = ['ЯНВ','ФЕВ','МАР','АПР','МАЙ','ИЮН','ИЮЛ','АВГ','СЕН','ОКТ','НОЯ','ДЕК']
  - var months_en = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC']
  .tour-date
    strong= d.getDate()
    span= lang === 'ru' ? months_ru[d.getMonth()] : months_en[d.getMonth()]

block content
  .hero
    .hero-photo
      if directions.length && directions[0].heroImageSizes
        picture
          source(media='(max-width:800px)' srcset=directions[0].heroImageSizes.w800)
          img(src=directions[0].heroImageSizes.w1400 alt='Эка Елисеева')
      else
        .hero-photo-placeholder ФОТО ЭКИ
    .hero-text
      .hero-eyebrow= lang === 'ru' ? 'Авторские экскурсии · Тбилиси' : 'Private tours · Tbilisi'
      .hero-name
        | Эка
        br
        | Елисеева
      .hero-bio= lang === 'ru' ? 'Живу в Грузии 12 лет. Показываю страну такой, какой её не видят из окна туристического автобуса — через людей, вино, архитектуру и горы.' : 'I have lived in Georgia for 12 years. I show the country as you won\'t see it from a tour bus window — through people, wine, architecture and mountains.'
      .hero-cta
        a.btn(href=`/${lang}/`)= lang === 'ru' ? 'Смотреть туры' : 'See tours'
        a.btn.btn-outline(href=`/${lang}/about`)= lang === 'ru' ? 'Обо мне' : 'About me'

  if directions.length
    .section
      .section-header
        .section-title= lang === 'ru' ? 'Направления' : 'Destinations'
      .directions-grid
        each dir in directions
          a.dir-card(href=`/${lang}/directions/${dir.slug}`)
            .dir-image
              if dir.heroImageSizes
                picture
                  source(media='(max-width:400px)' srcset=dir.heroImageSizes.w400)
                  img(src=dir.heroImageSizes.w800 alt=lang === 'ru' ? dir.titleRu : dir.titleEn)
              .dir-overlay
              .dir-label
                .dir-name= lang === 'ru' ? dir.titleRu : dir.titleEn

  if upcomingTours.length
    .section(style='padding-top:0')
      .section-header
        .section-title= lang === 'ru' ? 'Ближайшие туры' : 'Upcoming tours'
      .tours-list
        each tour in upcomingTours
          a.tour-row(href=`/${lang}/tours/${tour.id}`)
            +tourDate(tour)
            div
              .tour-name= lang === 'ru' ? tour.titleRu : tour.titleEn
              .tour-detail
                | #{lang === 'ru' ? tour.durationRu : tour.durationEn}
                if tour.maxParticipants
                  |  · #{lang === 'ru' ? 'до ' + tour.maxParticipants + ' чел' : 'up to ' + tour.maxParticipants}
            .tour-price
              .amount= tour.price + ' ' + (tour.currency || 'USD')
              .currency= lang === 'ru' ? 'за человека' : 'per person'
