extends layout

include _request-form

mixin tourDate(tour)
  - var d = tour.date && tour.date.toDate ? tour.date.toDate() : new Date(tour.date)
  - var months_ru = ['ЯНВ','ФЕВ','МАР','АПР','МАЙ','ИЮН','ИЮЛ','АВГ','СЕН','ОКТ','НОЯ','ДЕК']
  - var months_en = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC']
  .tour-date
    strong= d.getDate()
    span= lang === 'ru' ? months_ru[d.getMonth()] : months_en[d.getMonth()]

block content
  .breadcrumb
    a(href=`/${lang}/`)= lang === 'ru' ? 'Главная' : 'Home'
    |  /
    a(href=`/${lang}/`)= lang === 'ru' ? 'Направления' : 'Destinations'
    |  / #{lang === 'ru' ? direction.titleRu : direction.titleEn}

  - var heroImg = images && images.find(function(i){ return i.role === 'hero'; }) || direction.heroImageSizes
  .dir-hero
    if heroImg
      picture
        source(media='(max-width:800px)' srcset=heroImg.w800)
        source(media='(max-width:1400px)' srcset=heroImg.w1400)
        img(src=heroImg.w2400 alt=lang === 'ru' ? direction.titleRu : direction.titleEn)
    .dir-hero-overlay
    if direction.startLat && direction.finishLat
      canvas#route-map(
        data-start-lat=direction.startLat
        data-start-lng=direction.startLng
        data-finish-lat=direction.finishLat
        data-finish-lng=direction.finishLng
        data-start-name=direction.startName || (lang === 'ru' ? 'Старт' : 'Start')
        data-finish-name=direction.finishName || (lang === 'ru' ? 'Финиш' : 'Finish')
        data-polyline=direction.routePolyline || ''
      )
    .dir-hero-content
      .dir-hero-label= lang === 'ru' ? 'Направление' : 'Destination'
      .dir-hero-title= lang === 'ru' ? direction.titleRu : direction.titleEn

  if direction.startLat && direction.finishLat
    script(src='/javascripts/eka/route-map.js')

  .dir-intro
    .dir-intro-text
      p= lang === 'ru' ? direction.descRu : direction.descEn
    .dir-meta-list
      if direction.metaDistanceRu || direction.metaDistanceEn
        .meta-item
          .meta-label= lang === 'ru' ? 'Расстояние' : 'Distance'
          .meta-value= lang === 'ru' ? direction.metaDistanceRu : direction.metaDistanceEn
      if direction.metaDurationRu || direction.metaDurationEn
        .meta-item
          .meta-label= lang === 'ru' ? 'Длительность' : 'Duration'
          .meta-value= lang === 'ru' ? direction.metaDurationRu : direction.metaDurationEn
      if direction.metaGroupSize
        .meta-item
          .meta-label= lang === 'ru' ? 'Группа' : 'Group size'
          .meta-value= direction.metaGroupSize
      if direction.metaSeasonRu || direction.metaSeasonEn
        .meta-item
          .meta-label= lang === 'ru' ? 'Сезон' : 'Season'
          .meta-value= lang === 'ru' ? direction.metaSeasonRu : direction.metaSeasonEn


  - var galleryImgs = (images && images.filter(function(i){ return i.role === 'gallery'; })) || []
  - var galleryList = galleryImgs.length ? galleryImgs : (direction.gallery || [])
  if galleryList.length
    .section
      .gallery
        each item, i in galleryList
          - var caption = item.caption || ''
          - var lbSrcset = [item.w400 && (item.w400+' 400w'), item.w800 && (item.w800+' 800w'), item.w1400 && (item.w1400+' 1400w'), item.w2400 && (item.w2400+' 2400w')].filter(Boolean).join(', ')
          .gallery-item(class=i === 0 ? 'tall' : '' data-lb=i data-src=item.w1400 || item.w800 data-srcset=lbSrcset data-caption=caption)
            picture
              source(media='(max-width:400px)' srcset=item.w400)
              source(media='(max-width:800px)' srcset=item.w800)
              img(src=item.w1400 alt=caption loading='lazy')

    #lb.lb-overlay
      button.lb-close(type='button' aria-label='Close') ×
      button.lb-prev(type='button' aria-label='Previous') ‹
      button.lb-next(type='button' aria-label='Next') ›
      .lb-img-wrap
        img.lb-img(src='' alt='')
      .lb-caption
      .lb-counter

    script.
      (function() {
        var items = Array.from(document.querySelectorAll('.gallery-item[data-lb]'));
        var srcs    = items.map(function(el) { return el.dataset.src; });
        var srcsets = items.map(function(el) { return el.dataset.srcset || ''; });
        var captions = items.map(function(el) { return el.dataset.caption || ''; });
        var overlay   = document.getElementById('lb');
        var img       = overlay.querySelector('.lb-img');
        var caption   = overlay.querySelector('.lb-caption');
        var counter   = overlay.querySelector('.lb-counter');
        var cur = 0;
        var tiles = ['01_borjgali_rosette','02_vine_lattice','03_qvevri_stripes','04_khevsur_diamonds','05_mtskheta_cross_grid','06_mountain_meander','07_pomegranate_rosettes','08_script_echo','09_tamada_horn_waves','10_stone_interlace'];
        var currentTile = tiles[Math.floor(Math.random() * tiles.length)];
        overlay.style.setProperty('--lb-tile', 'url(/images/eka/tiles/' + currentTile + '.svg)');

        function show(i) {
          cur = (i + srcs.length) % srcs.length;
          img.src = srcs[cur];
          img.srcset = srcsets[cur];
          img.sizes = '100vw';
          img.alt = captions[cur];
          caption.textContent = captions[cur];
          caption.style.display = captions[cur] ? '' : 'none';
          counter.textContent = (cur + 1) + ' / ' + srcs.length;
          overlay.classList.add('lb-open');
        }
        function close() { overlay.classList.remove('lb-open'); img.src = ''; img.srcset = ''; }

        items.forEach(function(el) {
          el.style.cursor = 'zoom-in';
          el.addEventListener('click', function() { show(parseInt(el.dataset.lb)); });
        });
        overlay.querySelector('.lb-close').addEventListener('click', close);
        overlay.querySelector('.lb-prev').addEventListener('click', function() { show(cur - 1); });
        overlay.querySelector('.lb-next').addEventListener('click', function() { show(cur + 1); });
        overlay.addEventListener('click', function(e) { if (e.target === overlay || e.target === overlay.querySelector('.lb-img-wrap')) close(); });
        document.addEventListener('keydown', function(e) {
          if (!overlay.classList.contains('lb-open')) return;
          if (e.key === 'ArrowLeft') show(cur - 1);
          else if (e.key === 'ArrowRight') show(cur + 1);
          else if (e.key === 'Escape') close();
        });
      })();

  - var extraText = lang === 'ru' ? direction.extraTextRu : direction.extraTextEn
  if extraText
    .extra-text
      .extra-text-inner
        .extra-text-label= lang === 'ru' ? 'Подробнее' : 'More'
        .extra-text-body
          each para in extraText.split('\n\n')
            p= para

  if tours.length
    .section
      .tours-list
        each tour in tours
          a.tour-row(href=`/${lang}/tours/${tour.id}`)
            +tourDate(tour)
            div
              .tour-name= lang === 'ru' ? tour.titleRu : tour.titleEn
              .tour-detail
                | #{lang === 'ru' ? tour.durationRu : tour.durationEn}
                if tour.maxParticipants
                  |  · #{lang === 'ru' ? 'до ' + tour.maxParticipants + ' чел' : 'up to ' + tour.maxParticipants}
            .tour-price
              .amount= tour.price + ' ' + (tour.currency || 'USD')
              .currency= lang === 'ru' ? 'за человека' : 'per person'

  if reviews && reviews.length
    .extra-text
      .extra-text-inner
        .extra-text-label= lang === 'ru' ? 'Отзывы' : 'Reviews'
        .reviews-list
          each review in reviews
            .review-card
              .review-text= review.reviewText
              .review-author
                | — #{review.name}
                if review.tourTitle
                  | , #{review.tourTitle}

  .section
    if tours.length
      .section-no-tours= lang === 'ru' ? 'Нет подходящего тура?' : 'No suitable tour?'
    +requestForm({
      formTitle: lang === 'ru' ? 'Хочу в ' + direction.titleRu : 'I want to visit ' + direction.titleEn,
      formSub: lang === 'ru' ? 'Оставьте заявку — Эка свяжется и обсудит удобные даты' : 'Leave a request — Eka will get in touch to discuss dates',
      hiddenFields: { type: 'direction', directionId: direction.id, directionSlug: direction.slug }
    })
