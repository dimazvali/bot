doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
  body.admin-body
    nav.admin-nav
      a(href='/admin/') Eka Admin
      a(href='/admin/directions') Направления
      a(href='/admin/attractions') Места
      a(href='/admin/tours') Туры
      a(href='/admin/requests') Заявки
      a(href='/admin/clients') Клиенты
      a(href='/admin/reviews') Отзывы
      a(href='/admin/discounts') Скидки
      a(href='/admin/stickers') Стикеры
      a(href='/admin/bot') Бот
      a(href='/admin/admins') Администраторы
      a(href='/admin/profile') Профиль
      a(href='/admin/help') Справка
      a(href='/admin/logout') Выйти
    .admin-content
      .section-header(style='margin-bottom:16px')
        .admin-title(style='margin:0') Направления
        a.admin-btn(href='/admin/directions/new') + Новое
      p(style='font-size:11px;color:#bbb;margin-bottom:12px') Перетащите строки для изменения порядка, затем нажмите «Сохранить порядок».
      table.admin-table(id='directionsList')
        thead
          tr
            th ☰
            th Название
            th Slug
            th Туров
            th Статус
            th
        tbody
          each dir in directions
            tr(draggable='true' data-id=dir.id)
              td(style='cursor:grab;color:#bbb') ☰
              td= dir.titleRu
              td(style='color:#bbb;font-size:11px')= dir.slug
              td= tourCount[dir.id] || 0
              td
                if dir.published
                  span.badge.badge-published Опубликовано
                else
                  span.badge.badge-draft Черновик
              td: a(href='/admin/directions/' + dir.id + '/edit') Редактировать
          else
            tr: td(colspan='5' style='color:#bbb;text-align:center;padding:20px') Нет направлений
      br
      button.admin-btn(id='saveOrderBtn') Сохранить порядок
    script(src='/javascripts/eka/admin.js')
    script(src='/javascripts/eka/main.js')
    script.
      (function() {
        var tbody = document.querySelector('#directionsList tbody');
        var saveBtn = document.getElementById('saveOrderBtn');
        var dragging = null;

        tbody.addEventListener('dragstart', function(e) {
          dragging = e.target.closest('tr');
          dragging.style.opacity = '.4';
        });
        tbody.addEventListener('dragend', function() {
          dragging.style.opacity = '';
          dragging = null;
        });
        tbody.addEventListener('dragover', function(e) {
          e.preventDefault();
          var target = e.target.closest('tr');
          if (!target || target === dragging) return;
          var rows = Array.from(tbody.querySelectorAll('tr'));
          var fromIdx = rows.indexOf(dragging);
          var toIdx = rows.indexOf(target);
          if (fromIdx < toIdx) target.after(dragging);
          else target.before(dragging);
        });

        saveBtn.addEventListener('click', function() {
          var ids = Array.from(tbody.querySelectorAll('tr[data-id]')).map(function(r) { return r.dataset.id; });
          saveBtn.disabled = true;
          saveBtn.textContent = 'Сохраняю…';
          fetch('/admin/directions/reorder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: ids }),
          }).then(function(r) { return r.json(); }).then(function(d) {
            saveBtn.textContent = d.ok ? 'Сохранено ✓' : 'Ошибка';
            saveBtn.disabled = false;
          }).catch(function() {
            saveBtn.textContent = 'Ошибка';
            saveBtn.disabled = false;
          });
        });
      }());
