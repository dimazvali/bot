doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
  body.admin-body
    nav.admin-nav
      a(href='/admin/') Eka Admin
      a(href='/admin/directions') Направления
      a(href='/admin/attractions') Места
      a(href='/admin/tours') Туры
      a(href='/admin/requests') Заявки
      a(href='/admin/clients') Клиенты
      a(href='/admin/reviews') Отзывы
      a(href='/admin/discounts') Скидки
      a(href='/admin/stickers') Стикеры
      a(href='/admin/bot') Бот
      a(href='/admin/admins') Администраторы
      a(href='/admin/profile') Профиль
      a(href='/admin/logout') Выйти
    .admin-content
      .section-header(style='margin-bottom:16px;display:flex;align-items:center;gap:16px')
        .admin-title(style='margin:0') Достопримечательности
        a.admin-btn(href='/admin/attractions/new') + Добавить
      table.admin-table
        thead
          tr
            th Название
            th Регион
            th Статус
            th
        tbody
          each attr in attractions
            tr
              td= attr.titleRu
              td= (dirMap[attr.directionId] && dirMap[attr.directionId].titleRu) || '—'
              td
                if attr.published
                  span.badge.badge-published Опубликовано
                else
                  span.badge.badge-draft Черновик
              td: a(href='/admin/attractions/' + attr.id + '/edit') Редактировать
          else
            tr: td(colspan='4' style='color:#bbb;text-align:center;padding:20px') Нет мест
    script(src='/javascripts/eka/admin.js')
