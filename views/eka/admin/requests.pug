doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
    style.
      .req-row { cursor: pointer; }
      .req-detail { display: none; padding: 12px 14px; background: #fafafa; border-bottom: 1px solid #f0f0f0; }
      .req-row.open + .req-detail { display: table-row; }
      .req-detail td { padding: 12px 14px; font-size: 12px; color: #555; }
  body.admin-body
    nav.admin-nav
      a(href='/admin/') Eka Admin
      a(href='/admin/directions') Направления
      a(href='/admin/tours') Туры
      a(href='/admin/requests') Заявки
      a(href='/admin/profile') Профиль
      a(href='/admin/logout') Выйти
    .admin-content
      .section-header(style='margin-bottom:16px')
        .admin-title(style='margin:0') Заявки
      .admin-field(style='margin-bottom:20px')
        a.admin-btn.btn-sm(href='/admin/requests' style=!activeStatus?'background:#111;color:#fff':'') Все
        |
        a.admin-btn.btn-sm(href='/admin/requests?status=new' style=activeStatus==='new'?'background:#111;color:#fff':'') Новые
        |
        a.admin-btn.btn-sm(href='/admin/requests?status=contacted' style=activeStatus==='contacted'?'background:#111;color:#fff':'') Связались
        |
        a.admin-btn.btn-sm(href='/admin/requests?status=done' style=activeStatus==='done'?'background:#111;color:#fff':'') Готово
      table.admin-table
        thead
          tr
            th Дата
            th Тип
            th Место
            th Имя
            th Контакт
            th Статус
        tbody
          each req in requests
            - var d = req.createdAt && req.createdAt.toDate ? req.createdAt.toDate() : new Date(req.createdAt || 0)
            tr.req-row
              td= d.toLocaleDateString('ru-RU')
              td= req.type === 'tour' ? 'Тур' : 'Направление'
              td= req.directionSlug || req.tourTitle || '—'
              td= req.name
              td= (req.contactType || '?') + ': ' + (req.contact || '?')
              td
                span.badge(class='badge-' + (req.status || 'new'))= req.status || 'new'
            tr.req-detail
              td(colspan='6')
                if req.preferredDates
                  p #[strong Даты:] #{req.preferredDates}
                if req.message
                  p #[strong Сообщение:] #{req.message}
                p #[strong Язык:] #{req.lang || '—'}
                form(method='POST' action='/admin/requests/' + req.id + '/status' style='margin-top:10px;display:flex;gap:8px')
                  select(name='status')
                    option(value='new' selected=req.status==='new') new
                    option(value='contacted' selected=req.status==='contacted') contacted
                    option(value='done' selected=req.status==='done') done
                  button.admin-btn.btn-sm(type='submit') Сохранить статус
          else
            tr: td(colspan='5' style='color:#bbb;text-align:center;padding:20px') Нет заявок
    script.
      document.querySelectorAll('.req-row').forEach(function(row) {
        row.addEventListener('click', function(e) {
          if (e.target.closest('form')) return;
          this.classList.toggle('open');
        });
      });
