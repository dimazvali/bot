doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
  body.admin-body
    nav.admin-nav
      a(href='/admin/') Eka Admin
      a(href='/admin/directions') Направления
      a(href='/admin/attractions') Места
      a(href='/admin/tours') Туры
      a(href='/admin/requests') Заявки
      a(href='/admin/clients') Клиенты
      a(href='/admin/reviews') Отзывы
      a(href='/admin/discounts') Скидки
      a(href='/admin/stickers') Стикеры
      a(href='/admin/bot') Бот
      a(href='/admin/admins') Администраторы
      a(href='/admin/profile') Профиль
      a(href='/admin/help') Справка
      a(href='/admin/logout') Выйти
    .admin-content
      .admin-title Дашборд
        if locals.adminName
          span(style='font-size:14px;font-weight:400;color:#888;margin-left:12px') #{locals.adminName}
      .admin-stats
        .admin-stat
          .admin-stat-num= newRequestCount
          .admin-stat-label Новых заявок
        .admin-stat
          .admin-stat-num= upcomingTours.length
          .admin-stat-label Предстоящих туров
      .section-header(style='margin-bottom:16px')
        .section-title(style='font-size:16px') Предстоящие туры
        a.admin-btn.btn-sm(href='/admin/tours/new') + Новый тур
      if upcomingTours.length
        table.admin-table
          thead
            tr
              th Дата
              th Направление
              th Название
              th Цена
          tbody
            each tour in upcomingTours
              - var d = tour.date && tour.date.toDate ? tour.date.toDate() : new Date(tour.date)
              tr
                td= d.toLocaleDateString('ru-RU')
                td= tour.directionSlug || '—'
                td: a(href='/admin/tours/' + tour.id + '/edit')= tour.titleRu
                td= tour.price + ' ' + (tour.currency || '')
      else
        p(style='color:#bbb;font-size:13px') Нет предстоящих туров
      br
      a.admin-btn(href='/admin/directions/new') + Новое направление
    script(src='/javascripts/eka/admin.js')
