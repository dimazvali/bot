doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
    style.
      .gallery-list-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
      .gallery-card { background: #fff; border: 1px solid #e8e8e8; }
      .gallery-card-thumb { width: 100%; aspect-ratio: 16/10; object-fit: cover; display: block; background: #e8e8e8; }
      .gallery-card-thumb-empty { width: 100%; aspect-ratio: 16/10; display: flex; align-items: center; justify-content: center; background: #f4f4f4; color: #bbb; font-size: 11px; }
      .gallery-card-body { padding: 12px 14px; }
      .gallery-card-title { font-size: 14px; margin-bottom: 6px; }
      .gallery-card-meta { font-size: 11px; color: #aaa; margin-bottom: 10px; }
      .gallery-shortcode { display: flex; gap: 6px; align-items: center; }
      .gallery-shortcode code { font-size: 11px; background: #f4f4f4; padding: 3px 6px; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .gallery-shortcode button { font-size: 10px; border: 1px solid #ccc; background: #fff; padding: 3px 8px; cursor: pointer; }
      .gallery-shortcode button:hover { background: #f4f4f4; }
      .gallery-card-actions { margin-top: 10px; display: flex; gap: 10px; align-items: center; }
      .gallery-card-actions a { font-size: 11px; color: #005a9e; }
  body.admin-body
    include _nav
    .admin-content
      .admin-title-row
        .admin-title Галереи
        a.admin-btn(href='/admin/galleries/new') + Добавить
      p.admin-hint(style='margin-bottom:20px') Переиспользуемые галереи фото. Вставляйте шорткод в описание тура на отдельной строке, чтобы показать галерею в нужном месте.
      if galleries && galleries.length
        .gallery-list-grid
          each g in galleries
            .gallery-card
              if g.thumb
                img.gallery-card-thumb(src=g.thumb.w400 alt='')
              else
                .gallery-card-thumb-empty Нет фото
              .gallery-card-body
                .gallery-card-title= g.title || 'Без названия'
                .gallery-card-meta= g.count + ' фото'
                .gallery-shortcode
                  code(id='sc-' + g.id) [gallery:#{g.id}]
                  button(type='button' data-copy=g.id) Копировать
                .gallery-card-actions
                  a(href='/admin/galleries/' + g.id + '/edit') Редактировать
      else
        p(style='color:#bbb;font-size:13px') Пока нет ни одной галереи
    script.
      document.querySelectorAll('.gallery-shortcode button').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var code = document.getElementById('sc-' + btn.dataset.copy).textContent;
          navigator.clipboard.writeText(code).then(function() {
            var old = btn.textContent;
            btn.textContent = 'Скопировано';
            setTimeout(function() { btn.textContent = old; }, 1200);
          });
        });
      });
    script(src='/javascripts/eka/admin.js')
