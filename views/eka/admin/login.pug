doctype html
html
  head
    title= title
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width,initial-scale=1')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
  body.admin-body
    .admin-login
      h2 Eka Admin
      if error
        .admin-error= error
      form(method='POST' action='/admin/login')
        .admin-field
          label Пароль
          input(type='password' name='pass' autofocus required)
        button.admin-btn(type='submit') Войти
