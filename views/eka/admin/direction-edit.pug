doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
  body.admin-body
    include _nav
    .admin-content
      .admin-title= directionId ? (direction.titleRu || 'Редактировать') : 'Новое направление'
      - var formAction = directionId ? '/admin/directions/' + directionId + '/edit' : '/admin/directions/new/edit'
      form.admin-form(method='POST' action=formAction enctype='multipart/form-data')
        h3(style='font-size:14px;font-weight:500;margin-bottom:16px;border-bottom:1px solid #e8e8e8;padding-bottom:8px') Основное
        .admin-2col
          .admin-field
            label Заголовок (RU)
            input(type='text' name='titleRu' value=direction && direction.titleRu || '' required)
          .admin-field
            label Title (EN)
            input(type='text' name='titleEn' value=direction && direction.titleEn || '' required)
        .admin-field
          label Slug (URL)
          input(type='text' name='slug' value=direction && direction.slug || '' placeholder='kazbegi' required)
          p.admin-hint Только латинские буквы, цифры и дефис. Пример: kazbegi
        .admin-2col
          .admin-field
            label Описание (RU)
            textarea(name='descRu')= direction && direction.descRu || ''
          .admin-field
            label Description (EN)
            textarea(name='descEn')= direction && direction.descEn || ''
        .admin-2col
          .admin-field
            label Дополнительный текст (RU, необязательно)
            textarea(name='extraTextRu' style='min-height:140px')= direction && direction.extraTextRu || ''
            p.admin-hint Отображается после галереи. Абзацы разделяйте двойным переносом строки.
          .admin-field
            label Additional text (EN, optional)
            textarea(name='extraTextEn' style='min-height:140px')= direction && direction.extraTextEn || ''

        h3(style='font-size:14px;font-weight:500;margin:24px 0 16px;border-bottom:1px solid #e8e8e8;padding-bottom:8px') Мета-данные
        .admin-2col
          .admin-field
            label Длительность (RU)
            input(type='text' name='metaDurationRu' value=direction && direction.metaDurationRu || '' placeholder='1–2 дня')
          .admin-field
            label Duration (EN)
            input(type='text' name='metaDurationEn' value=direction && direction.metaDurationEn || '' placeholder='1–2 days')
        .admin-2col
          .admin-field
            label Сезон (RU)
            input(type='text' name='metaSeasonRu' value=direction && direction.metaSeasonRu || '' placeholder='Май — Октябрь')
          .admin-field
            label Season (EN)
            input(type='text' name='metaSeasonEn' value=direction && direction.metaSeasonEn || '' placeholder='May — October')
        .admin-2col
          .admin-field
            label Расстояние (RU)
            input(type='text' name='metaDistanceRu' value=direction && direction.metaDistanceRu || '' placeholder='150 км от Тбилиси')
          .admin-field
            label Distance (EN)
            input(type='text' name='metaDistanceEn' value=direction && direction.metaDistanceEn || '' placeholder='150 km from Tbilisi')
        .admin-2col
          .admin-field
            label Размер группы (RU)
            input(type='text' name='metaGroupSizeRu' value=direction && (direction.metaGroupSizeRu || direction.metaGroupSize) || '' placeholder='до 8 человек')
          .admin-field
            label Group size (EN)
            input(type='text' name='metaGroupSizeEn' value=direction && direction.metaGroupSizeEn || '' placeholder='up to 8 people')

        h3(style='font-size:14px;font-weight:500;margin:24px 0 16px;border-bottom:1px solid #e8e8e8;padding-bottom:8px') Маршрут (координаты)
        p.admin-hint(style='margin-bottom:12px') Используются для анимации на странице направления. При сохранении маршрут автоматически запрашивается у Google Maps (если настроен ключ API). Десятичные градусы, например: 41.6945, 44.8015
        .admin-2col
          .admin-field
            label Старт — название
            input(type='text' name='startName' value=direction && direction.startName || '' placeholder='Тбилиси')
          .admin-field
            label Финиш — название
            input(type='text' name='finishName' value=direction && direction.finishName || '' placeholder='Казбеги')
        .admin-2col
          .admin-field
            label Старт — широта (lat)
            input(type='number' step='0.0001' name='startLat' value=direction && direction.startLat || '' placeholder='41.6945')
          .admin-field
            label Старт — долгота (lng)
            input(type='number' step='0.0001' name='startLng' value=direction && direction.startLng || '' placeholder='44.8015')
        .admin-2col
          .admin-field
            label Финиш — широта (lat)
            input(type='number' step='0.0001' name='finishLat' value=direction && direction.finishLat || '' placeholder='42.6697')
          .admin-field
            label Финиш — долгота (lng)
            input(type='number' step='0.0001' name='finishLng' value=direction && direction.finishLng || '' placeholder='44.6467')

        h3(style='font-size:14px;font-weight:500;margin:24px 0 16px;border-bottom:1px solid #e8e8e8;padding-bottom:8px') Изображения
        - var heroImg = images && images.find(function(i){ return i.role === 'hero'; })
        - var heroFallback = !heroImg && direction && direction.heroImageSizes
        .admin-field
          label Hero-изображение (загрузить новое)
          input(type='file' name='heroImage' accept='image/*')
          if heroImg
            p.admin-hint(style='margin-top:8px') Текущее:
            img(src=heroImg.w400 style='max-width:200px;margin-top:4px')
          else if heroFallback
            p.admin-hint(style='margin-top:8px') Текущее (старый формат):
            img(src=heroFallback.w400 style='max-width:200px;margin-top:4px')
        .admin-field
          label Галерея (добавить изображения)
          input(type='file' name='galleryImages' accept='image/*' multiple)

        h3(style='font-size:14px;font-weight:500;margin:24px 0 16px;border-bottom:1px solid #e8e8e8;padding-bottom:8px') Публикация
        .admin-field
          label
            input(type='checkbox' name='published' checked=direction && direction.published)
            |  Опубликовано (видно на сайте)

        .admin-field(style='display:flex;gap:12px;align-items:center')
          button.admin-btn(type='submit') Сохранить

      - var galleryImgs = images && images.filter(function(i){ return i.role === 'gallery'; })
      - var galleryFallback = (!galleryImgs || !galleryImgs.length) && direction && direction.gallery && direction.gallery.length
      if galleryImgs && galleryImgs.length
        .admin-field(style='margin-top:16px')
          h3(style='font-size:14px;font-weight:500;margin-bottom:12px;border-bottom:1px solid #e8e8e8;padding-bottom:8px') Галерея
          p.admin-hint(style='margin-bottom:8px') Перетащите фото для изменения порядка
          .admin-img-grid#gallery-grid
            each img in galleryImgs
              .admin-img-item(draggable='true' data-id=img.id)
                img(src=img.w400 alt=img.caption || '')
                form(method='POST' action='/admin/images/' + img.id + '/delete' style='display:inline')
                  input(type='hidden' name='back' value=directionId)
                  button.admin-img-del(type='submit' title='Удалить') ✕
                input.img-caption-input(type='text' placeholder='Подпись к фото' value=img.caption || '' data-id=img.id)
        script.
          (function () {
            /* ── caption save ── */
            document.querySelectorAll('.img-caption-input').forEach(function(inp) {
              var saved = inp.value;
              function save() {
                if (inp.value === saved) return;
                saved = inp.value;
                fetch('/admin/images/' + inp.dataset.id + '/caption', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ caption: inp.value })
                });
              }
              inp.addEventListener('blur', save);
              inp.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); save(); inp.blur(); } });
            });

            /* ── drag-and-drop reorder ── */
            var grid = document.getElementById('gallery-grid');
            var dragged = null;

            grid.addEventListener('dragstart', function(e) {
              dragged = e.target.closest('.admin-img-item');
              if (!dragged) return;
              dragged.classList.add('dragging');
              e.dataTransfer.effectAllowed = 'move';
            });

            grid.addEventListener('dragend', function() {
              if (dragged) dragged.classList.remove('dragging');
              document.querySelectorAll('.admin-img-item.drag-over').forEach(function(el) {
                el.classList.remove('drag-over');
              });
              dragged = null;
            });

            grid.addEventListener('dragover', function(e) {
              e.preventDefault();
              e.dataTransfer.dropEffect = 'move';
              var target = e.target.closest('.admin-img-item');
              if (!target || target === dragged) return;
              document.querySelectorAll('.admin-img-item.drag-over').forEach(function(el) {
                el.classList.remove('drag-over');
              });
              target.classList.add('drag-over');
            });

            grid.addEventListener('dragleave', function(e) {
              var target = e.target.closest('.admin-img-item');
              if (target) target.classList.remove('drag-over');
            });

            grid.addEventListener('drop', function(e) {
              e.preventDefault();
              var target = e.target.closest('.admin-img-item');
              if (!target || target === dragged || !dragged) return;
              target.classList.remove('drag-over');

              /* insert before or after depending on position */
              var items = Array.from(grid.querySelectorAll('.admin-img-item'));
              var fromIdx = items.indexOf(dragged);
              var toIdx   = items.indexOf(target);
              if (fromIdx < toIdx) {
                grid.insertBefore(dragged, target.nextSibling);
              } else {
                grid.insertBefore(dragged, target);
              }

              /* persist new order */
              var newIds = Array.from(grid.querySelectorAll('.admin-img-item')).map(function(el) {
                return el.dataset.id;
              });
              fetch('/admin/images/reorder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ids: newIds })
              });
            });
          })();
      else if galleryFallback
        .admin-field(style='margin-top:16px')
          h3(style='font-size:14px;font-weight:500;margin-bottom:12px;border-bottom:1px solid #e8e8e8;padding-bottom:8px') Галерея (старый формат)
          p.admin-hint(style='margin-bottom:8px') Загрузите новые фото — они заменят старые
          .admin-img-grid
            each img in direction.gallery
              .admin-img-item
                img(src=img.w400 alt='')

      if directionId
        form(method='POST' action='/admin/directions/' + directionId + '/delete' style='margin-top:12px;display:inline' onsubmit='return confirm("Удалить направление?")')
          button.admin-btn.admin-btn-danger(type='submit') Удалить
    script(src='/javascripts/eka/admin.js')
