doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
  body.admin-body
    nav.admin-nav
      a(href='/admin/') Eka Admin
      a(href='/admin/directions') Направления
      a(href='/admin/tours') Туры
      a(href='/admin/requests') Заявки
      a(href='/admin/profile') Профиль
      a(href='/admin/logout') Выйти
    .admin-content
      .section-header(style='margin-bottom:16px')
        .admin-title(style='margin:0') Туры
        a.admin-btn(href='/admin/tours/new') + Новый
      table.admin-table
        thead
          tr
            th Дата
            th Направление
            th Название
            th Цена
            th Статус
            th
        tbody
          each tour in tours
            - var d = tour.date && tour.date.toDate ? tour.date.toDate() : new Date(tour.date)
            - var isPast = d < new Date()
            tr(style=isPast ? 'opacity:0.4' : '')
              td= d.toLocaleDateString('ru-RU')
              td= dirMap[tour.directionId] ? dirMap[tour.directionId].titleRu : '—'
              td= tour.titleRu
              td= tour.price + ' ' + (tour.currency || '')
              td
                if tour.published
                  span.badge.badge-published Опубликовано
                else
                  span.badge.badge-draft Черновик
              td: a(href='/admin/tours/' + tour.id + '/edit') Редактировать
          else
            tr: td(colspan='5' style='color:#bbb;text-align:center;padding:20px') Нет туров
