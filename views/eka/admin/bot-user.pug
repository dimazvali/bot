doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
    style.
      .bot-nav { display: flex; gap: 8px; margin-bottom: 20px; }
      .user-header { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #f0f0f0; }
      .user-avatar { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
      .user-avatar-placeholder { width: 52px; height: 52px; border-radius: 50%; background: #e8e8e8; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; color: #aaa; }
      .user-name { font-size: 16px; font-weight: 700; }
      .user-meta { font-size: 12px; color: #aaa; margin-top: 2px; }
      .user-badge { display: inline-block; font-size: 10px; padding: 2px 6px; border-radius: 3px; margin-left: 6px; vertical-align: middle; }
      .badge-active { background: #e6f4ea; color: #1a7f37; }
      .badge-inactive { background: #ffeaea; color: #c00; }
      .chat-wrap { border: 1px solid #eee; border-radius: 8px; overflow: hidden; margin-bottom: 16px; }
      .chat { display: flex; flex-direction: column; gap: 6px; max-height: 55vh; overflow-y: auto; padding: 16px; background: #f7f7f7; }
      .msg { display: flex; flex-direction: column; max-width: 72%; }
      .msg-in { align-self: flex-start; }
      .msg-out { align-self: flex-end; align-items: flex-end; }
      .msg-bubble { padding: 8px 12px; border-radius: 14px; font-size: 13px; line-height: 1.55; white-space: pre-wrap; word-break: break-word; }
      .msg-in .msg-bubble { background: #fff; border: 1px solid #e8e8e8; border-bottom-left-radius: 4px; }
      .msg-out .msg-bubble { background: #d4edff; border-bottom-right-radius: 4px; }
      .msg-media { color: #777; font-style: italic; }
      .msg-meta { font-size: 10px; color: #bbb; margin-top: 3px; }
      .msg-out .msg-meta { text-align: right; }
      .empty-chat { color: #ccc; font-size: 13px; text-align: center; padding: 32px 0; }
      .send-box { padding: 14px 16px; background: #fff; border-top: 1px solid #eee; }
      .send-box textarea { width: 100%; box-sizing: border-box; min-height: 76px; resize: vertical; font-size: 13px; padding: 8px 10px; border: 1px solid #ddd; border-radius: 6px; font-family: inherit; line-height: 1.5; }
      .send-box textarea:focus { outline: none; border-color: #c00; }
      .send-row { display: flex; gap: 8px; align-items: center; margin-top: 8px; }
      .send-row input[type=file] { font-size: 11px; flex: 1; }
      .photo-preview { display: none; width: 72px; height: 72px; object-fit: cover; border-radius: 4px; border: 1px solid #eee; margin-top: 6px; }
      .sent-ok { color: #1a7f37; font-size: 12px; padding: 8px 16px; background: #fff; border-top: 1px solid #eee; }
      .inactive-note { color: #bbb; font-size: 12px; padding: 10px 16px; background: #fff; border-top: 1px solid #eee; }
  body.admin-body
    include _nav
    .admin-content
      .bot-nav
        a.admin-btn.btn-sm(href='/admin/bot/messages') Приветствия
        a.admin-btn.btn-sm(href='/admin/bot/profile') Профиль бота
        a.admin-btn.btn-sm(href='/admin/bot/users' style='background:#111;color:#fff') Пользователи
        a.admin-btn.btn-sm(href='/admin/bot/broadcast') Рассылка

      .user-header
        if user.avatarUrl
          img.user-avatar(src=user.avatarUrl alt='')
        else
          .user-avatar-placeholder 👤
        div
          .user-name
            = [user.first_name, user.last_name].filter(Boolean).join(' ') || 'Без имени'
            span.user-badge(class=user.active ? 'badge-active' : 'badge-inactive')= user.active ? 'активен' : 'заблокировал'
          .user-meta
            if user.username
              | @#{user.username} ·
            | id: #{user.id}
            if user.lang
              |  · #{user.lang}

      .chat-wrap
        .chat#chat
          if messages && messages.length
            each m in messages
              - var d = m.createdAt && m.createdAt.toDate ? m.createdAt.toDate() : new Date(m.createdAt || 0)
              - var timeStr = d.toLocaleString('ru-RU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })
              .msg(class='msg-' + (m.direction || 'in'))
                .msg-bubble
                  if m.mediaType
                    span.msg-media= m.mediaType === 'photo' ? '🖼 Фото' : m.mediaType === 'video' ? '🎥 Видео' : m.mediaType === 'voice' ? '🎤 Голосовое' : m.mediaType === 'audio' ? '🎵 Аудио' : m.mediaType === 'document' ? '📎 Файл' : m.mediaType === 'sticker' ? '🎭 Стикер' : ('📎 ' + m.mediaType)
                    if m.text
                      br
                      = m.text
                  else
                    = m.text
                .msg-meta= timeStr + (m.direction === 'out' ? ' · ' + (m.sentBy || 'admin') : '')
          else
            p.empty-chat Сообщений пока нет

        if sent
          p.sent-ok ✓ Сообщение отправлено
        if user.active
          form.send-box(method='POST' action='/admin/bot/users/' + user.id + '/message' enctype='multipart/form-data')
            textarea(name='text' placeholder='Написать сообщение...' tabindex='1')
            .send-row
              input#photo-input(type='file' name='photo' accept='image/*' tabindex='3')
              button.admin-btn(type='submit' tabindex='2') Отправить
            img#photo-preview.photo-preview(src='' alt='')
        else
          p.inactive-note Пользователь заблокировал бота — отправка недоступна

    script.
      var chat = document.getElementById('chat');
      if (chat) chat.scrollTop = chat.scrollHeight;

      var photoInput = document.getElementById('photo-input');
      var photoPreview = document.getElementById('photo-preview');
      if (photoInput) {
        photoInput.addEventListener('change', function() {
          if (photoInput.files && photoInput.files[0]) {
            photoPreview.src = URL.createObjectURL(photoInput.files[0]);
            photoPreview.style.display = 'block';
          } else {
            photoPreview.style.display = 'none';
          }
        });
      }

      var MEDIA_LABELS = { photo: '🖼 Фото', video: '🎥 Видео', voice: '🎤 Голосовое', audio: '🎵 Аудио', document: '📎 Файл', sticker: '🎭 Стикер' };

      function formatTime(d) {
        return d.toLocaleString('ru-RU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
      }

      function appendMessage(m) {
        if (!chat) return;
        var d = m.createdAt ? new Date(m.createdAt) : new Date();
        var wrap = document.createElement('div');
        wrap.className = 'msg msg-' + (m.direction || 'in');
        var bubble = document.createElement('div');
        bubble.className = 'msg-bubble';
        if (m.mediaType) {
          var media = document.createElement('span');
          media.className = 'msg-media';
          media.textContent = MEDIA_LABELS[m.mediaType] || ('📎 ' + m.mediaType);
          bubble.appendChild(media);
          if (m.text) { bubble.appendChild(document.createElement('br')); bubble.appendChild(document.createTextNode(m.text)); }
        } else {
          bubble.textContent = m.text || '';
        }
        var meta = document.createElement('div');
        meta.className = 'msg-meta';
        meta.textContent = formatTime(d) + (m.direction === 'out' ? ' · ' + (m.sentBy || 'admin') : '');
        wrap.appendChild(bubble);
        wrap.appendChild(meta);
        chat.appendChild(wrap);
        chat.scrollTop = chat.scrollHeight;
      }

      var source = new EventSource('/admin/bot/users/!{user.id}/stream');
      source.onmessage = function(e) {
        try { appendMessage(JSON.parse(e.data)); } catch(_) {}
      };
