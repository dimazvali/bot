doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
    style.
      .admin-notif-row { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 6px; }
      .admin-notif-row label { display: flex; align-items: center; gap: 5px; font-size: 12px; cursor: pointer; font-weight: 400; }
      .tg-id-hint { font-size: 11px; color: #aaa; margin-top: 2px; }
  body.admin-body
    include _nav
    .admin-content
      .admin-title Администраторы

      if saved
        p(style='color:#1a7f37;font-size:13px;margin-bottom:16px') ✓ Сохранено
      if remind_ok
        p(style='color:#1a7f37;font-size:13px;margin-bottom:16px') ✓ Новый пароль отправлен в Telegram: #{remind_ok}
      if remind_err === 'no_tg'
        p(style='color:#c00;font-size:13px;margin-bottom:16px') ✗ Telegram ID не указан
      if remind_err === 'no_token'
        p(style='color:#c00;font-size:13px;margin-bottom:16px') ✗ Telegram бот не настроен

      if admins && admins.length
        each a in admins
          - var d = a.createdAt && a.createdAt.toDate ? a.createdAt.toDate() : new Date(a.createdAt || 0)
          - var isOwn = currentAdminId && currentAdminId === a.id
          - var canEdit = isSuperadmin || isOwn
          .admin-form(style='margin-bottom:16px;padding:16px;border:1px solid #eee;border-radius:4px')
            div(style='display:flex;align-items:center;gap:8px;margin-bottom:12px')
              strong(style='font-size:14px')= a.name
              if a.superadmin
                span(style='font-size:10px;background:#111;color:#fff;border-radius:3px;padding:2px 6px;letter-spacing:.5px') SUPER
              if isOwn
                span(style='font-size:11px;color:#888') (вы)
            if canEdit
              form(method='POST' action='/admin/admins/' + a.id + '/settings')
                .admin-2col
                  .admin-field
                    label Имя
                    input(type='text' name='name' value=a.name disabled style='background:#f9f9f9;color:#888')
                  .admin-field
                    label Telegram ID
                    input(type='text' name='tg_id' value=a.tg_id || '' placeholder='123456789')
                    p.tg-id-hint Числовой ID пользователя в Telegram (не username)
                .admin-field
                  label(style='font-size:12px;font-weight:600;margin-bottom:6px') Уведомления в Telegram
                  .admin-notif-row
                    label
                      input(type='checkbox' name='notify_requests' checked=a.notify_requests)
                      | Новые заявки
                    label
                      input(type='checkbox' name='notify_updates' checked=a.notify_updates)
                      | Обновления заявок
                    label
                      input(type='checkbox' name='notify_stats' checked=a.notify_stats)
                      | Статистика
                    label
                      input(type='checkbox' name='notify_messages' checked=a.notify_messages)
                      | Сообщения от бота
                .admin-field
                  label Новый пароль (оставьте пустым, чтобы не менять)
                  input(type='password' name='password' placeholder='••••••••' autocomplete='new-password')
                .admin-field(style='display:flex;gap:12px;align-items:center')
                  button.admin-btn.btn-sm(type='submit') Сохранить
                  span(style='font-size:11px;color:#aaa') добавлен #{d.toLocaleDateString('ru-RU')}
            else
              p(style='font-size:12px;color:#aaa;margin:0') добавлен #{d.toLocaleDateString('ru-RU')}
                if a.tg_id
                  |  · TG: #{a.tg_id}
            if isSuperadmin
              .admin-field(style='display:flex;gap:8px;margin-top:8px')
                form(method='POST' action='/admin/admins/' + a.id + '/remind-password')
                  button.admin-btn.btn-sm(type='submit' style='background:#f0f4ff;color:#2255cc') Напомнить пароль
                if !isOwn
                  form(method='POST' action='/admin/admins/' + a.id + '/delete' onsubmit='return confirm("Удалить администратора ' + a.name + '?")')
                    button.admin-btn.btn-sm.admin-btn-danger(type='submit') Удалить
      else
        p(style='color:#bbb;font-size:13px;margin-bottom:2rem') Дополнительных администраторов нет.

      if isSuperadmin
        h3(style='font-size:14px;font-weight:600;margin:24px 0 12px') Добавить администратора
        form.admin-form(method='POST' action='/admin/admins/add')
          .admin-2col
            .admin-field
              label Имя
              input(type='text' name='name' required placeholder='Например: Дима')
            .admin-field
              label Пароль
              input(type='password' name='password' required placeholder='Минимум 8 символов')
          .admin-field
            label Telegram ID
            input(type='text' name='tg_id' placeholder='123456789')
            p.tg-id-hint Числовой ID — можно узнать у @userinfobot
          .admin-field
            label(style='font-size:12px;font-weight:600;margin-bottom:6px') Уведомления в Telegram
            .admin-notif-row
              label
                input(type='checkbox' name='notify_requests')
                | Новые заявки
              label
                input(type='checkbox' name='notify_updates')
                | Обновления заявок
              label
                input(type='checkbox' name='notify_stats')
                | Статистика
              label
                input(type='checkbox' name='notify_messages')
                | Сообщения от бота
          button.admin-btn(type='submit') Добавить
