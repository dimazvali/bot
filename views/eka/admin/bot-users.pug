doctype html
html
  head
    title= title
    meta(charset='utf-8')
    link(rel='stylesheet' href='/stylesheets/eka/style.css')
    style.
      .bot-nav { display: flex; gap: 8px; margin-bottom: 20px; }
      .user-row { border: 1px solid #eee; border-radius: 6px; padding: 12px 14px; margin-bottom: 8px; }
      .user-row.hidden { display: none; }
      .user-header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
      .user-avatar { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; background: #f0f0f0; flex-shrink: 0; }
      .user-avatar-placeholder { width: 40px; height: 40px; border-radius: 50%; background: #e8e8e8; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; color: #aaa; }
      .user-name { font-size: 14px; font-weight: 600; }
      .user-meta { font-size: 11px; color: #aaa; }
      .user-badge { display: inline-block; font-size: 10px; padding: 2px 6px; border-radius: 3px; margin-left: 6px; }
      .badge-active { background: #e6f4ea; color: #1a7f37; }
      .badge-inactive { background: #ffeaea; color: #c00; }
      .badge-ru { background: #f0f4ff; color: #2255cc; }
      .badge-en { background: #fff8e6; color: #a06000; }
      .user-actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: flex-end; margin-top: 8px; }
      .msg-sent { color: #1a7f37; font-size: 12px; margin-top: 4px; }
      .photo-preview { display: none; width: 80px; height: 80px; object-fit: cover; border-radius: 4px; border: 1px solid #eee; margin-top: 6px; }
      #user-filter { width: 100%; box-sizing: border-box; padding: 7px 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px; margin-bottom: 14px; }
      #user-filter:focus { outline: none; border-color: #c00; }
      #filter-empty { display: none; color: #bbb; font-size: 13px; }
  body.admin-body
    include _nav
    .admin-content
      .admin-title Пользователи бота

      .bot-nav
        a.admin-btn.btn-sm(href='/admin/bot') Приветствия
        a.admin-btn.btn-sm(href='/admin/bot/profile') Профиль бота
        a.admin-btn.btn-sm(href='/admin/bot/users' style='background:#111;color:#fff') Пользователи
        a.admin-btn.btn-sm(href='/admin/bot/broadcast') Рассылка

      if users && users.length
        input#user-filter(type='text' placeholder='Поиск по имени, @username или id...' autocomplete='off')

        each u in users
          - var name = [u.first_name, u.last_name].filter(Boolean).join(' ') || 'Без имени'
          - var linkedClient = u.client_id && clientMap && clientMap[u.client_id]
          - var searchData = [name, u.username || '', u.id].join(' ').toLowerCase()
          .user-row(id='u-' + u.id data-search=searchData)
            .user-header
              if u.avatarUrl
                img.user-avatar(src=u.avatarUrl alt='')
              else
                .user-avatar-placeholder 👤
              div
                .user-name
                  a(href='/admin/bot/users/' + u.id style='color:inherit;text-decoration:none')= name
                  span.user-badge(class=u.active ? 'badge-active' : 'badge-inactive')= u.active ? 'активен' : 'заблокировал'
                  span.user-badge(class=u.lang && u.lang.startsWith('ru') ? 'badge-ru' : 'badge-en')= u.lang || '?'
                .user-meta
                  if u.username
                    | @#{u.username} ·
                  | id: #{u.id}
            .user-actions
              form(method='POST' action='/admin/bot/users/' + u.id + '/link-client' style='display:flex;gap:6px;align-items:center')
                select(name='clientId' style='font-size:12px;padding:4px 6px')
                  option(value='') — не привязан —
                  each c in (clients || [])
                    option(value=c.id selected=u.client_id===c.id)= (c.lastName || '') + ' ' + (c.firstName || '')
                button.admin-btn.btn-sm(type='submit') Привязать
              if linkedClient
                a.admin-btn.btn-sm(href='/admin/clients/' + u.client_id + '/edit' style='background:#f0f4ff;color:#2255cc;text-decoration:none')
                  = '↗ ' + (linkedClient.lastName || '') + ' ' + (linkedClient.firstName || '')
            if u.active
              form(method='POST' action='/admin/bot/users/' + u.id + '/message' enctype='multipart/form-data' style='margin-top:8px')
                textarea(name='text' rows='2' placeholder='Сообщение...' style='width:100%;box-sizing:border-box;font-size:12px;padding:6px 8px;border:1px solid #ddd;border-radius:4px;resize:vertical;font-family:inherit;line-height:1.4;margin-bottom:6px')
                div(style='display:flex;gap:8px;align-items:center')
                  input.photo-input(type='file' name='photo' accept='image/*' style='font-size:11px;flex:1')
                  button.admin-btn.btn-sm(type='submit') Отправить
                img.photo-preview(src='' alt='')
              if sent === u.id
                p.msg-sent ✓ Сообщение отправлено

        p#filter-empty Никого не найдено.
      else
        p(style='color:#bbb;font-size:13px') Пользователей пока нет.

    script.
      // Photo preview
      document.querySelectorAll('.photo-input').forEach(function(input) {
        var preview = input.closest('form').querySelector('.photo-preview');
        input.addEventListener('change', function() {
          if (input.files && input.files[0]) {
            preview.src = URL.createObjectURL(input.files[0]);
            preview.style.display = 'block';
          } else {
            preview.style.display = 'none';
            preview.src = '';
          }
        });
      });

      // User filter
      var filterInput = document.getElementById('user-filter');
      var rows = document.querySelectorAll('.user-row');
      var emptyMsg = document.getElementById('filter-empty');
      if (filterInput) {
        filterInput.addEventListener('input', function() {
          var q = filterInput.value.trim().toLowerCase();
          var visible = 0;
          rows.forEach(function(row) {
            var match = !q || (row.dataset.search || '').includes(q);
            row.classList.toggle('hidden', !match);
            if (match) visible++;
          });
          emptyMsg.style.display = visible === 0 ? 'block' : 'none';
        });
      }
