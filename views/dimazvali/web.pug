doctype html
html
  head
    meta(charset='utf-8')
    title dimazvali admin
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/axios/0.20.0/axios.js')
    script(src='/javascripts/common.js')
    script(src='https://maps.googleapis.com/maps/api/js?key=AIzaSyDtoqBwHVsUdk8OUwl-v82s2vsLEfuR5tM')
    link(rel='icon' type='image/x-icon' href='/images/dimazvali/favicon.ico')
    link(rel='stylesheet' href='/stylesheets/dimazvali/style.css')
    link(rel='stylesheet' href='/stylesheets/dimazvali/web.css')
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com')
    link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap')
    script(src='https://cdn.tiny.cloud/1/'+wysykey+'/tinymce/6/tinymce.min.js' referrerpolicy='origin')

  body
    button.sidebar-toggle(onclick='toggleDrawer()')
      span
      span
      span
    .sidebar-overlay#sidebar-overlay(onclick='toggleDrawer()')

    .admin-wrap
      .admin-sidebar#admin-sidebar
        .sidebar-logo dimazvali.com
        .sidebar-section
          .sidebar-heading Города
          #city-list
          button.sidebar-add(onclick="navigate('#cities')") + добавить город
        hr.sidebar-divider
        nav.sidebar-secondary
          a(onclick="navigate('#pages')" data-section='pages') Страницы
          a(onclick="navigate('#sections')" data-section='sections') Разделы
          a(onclick="navigate('#tags')" data-section='tags') Теги
          a(onclick="navigate('#reestr')" data-section='reestr') Реестр
          a(onclick="navigate('#authors')" data-section='authors') Ведущие
          a(onclick="navigate('#programs')" data-section='programs') Программы
          a(onclick="navigate('#shows')" data-section='shows') Выпуски
          a(onclick="navigate('#users')" data-section='users') Пользователи
          a(onclick="navigate('#settings')" data-section='settings') Настройки
          a(onclick="navigate('#logs')" data-section='logs') Логи
          a(onclick="navigate('#help')" data-section='help') Справка

      .admin-main
        #main

    script var logs = !{JSON.stringify(logs || [])}
    script(src='/javascripts/dimazvali/common-admin.js')
    script(src='/javascripts/dimazvali/router.js')
    script(src='/javascripts/dimazvali/geo.js')
    script(src='/javascripts/dimazvali/content.js')
    script(src='/javascripts/dimazvali/settings.js')
    script(src='/javascripts/dimazvali/media.js')
    script(src='/javascripts/dimazvali/web.js')
