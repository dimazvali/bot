
doctype html
html
  head
    title dimazvali.com admin
    //- script(src='https://telegram.org/js/telegram-web-app.js')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(name='description' content='Попробуйте — вам понравится.')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/axios/0.20.0/axios.js')
    script(src='/javascripts/common.js')
    script(src='https://maps.googleapis.com/maps/api/js?key=AIzaSyDtoqBwHVsUdk8OUwl-v82s2vsLEfuR5tM')
    link(rel='icon', type="image/x-icon", href='/images/dimazvali/favicon.ico')
    link(rel='stylesheet', href='/stylesheets/dimazvali/style.css')
    link(rel='stylesheet', href='/stylesheets/dimazvali/web.css')
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&family=Rubik+80s+Fade&display=swap")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;900&display=swap")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Oi&family=Oswald:wght@400;700;900&display=swap")
    script(src="https://cdn.tiny.cloud/1/"+wysykey+"/tinymce/6/tinymce.min.js" referrerpolicy="origin")
  body.mobile
    
    #left
      .sidebar-primary
        .sidebar-heading 🗺 Города
        #city-list
        button.sidebar-add(onclick="navigate('#cities')") + добавить город
      hr.sidebar-divider
      .sidebar-secondary
        h3(onclick="navigate('#pages')") Страницы
        h3(onclick="navigate('#sections')") Разделы
        h3(onclick="navigate('#tags')") Теги
        h3(onclick="navigate('#reestr')") Реестр
        h3(onclick="navigate('#authors')") Ведущие
        h3(onclick="navigate('#programs')") Программы
        h3(onclick="navigate('#shows')") Выпуски

        

        
    
    #menu(onclick="toggleDrawer()")

    #main
    script var logs = !{JSON.stringify(logs || [])}
    script(src='/javascripts/dimazvali/common-admin.js')
    script(src='/javascripts/dimazvali/router.js')
    script(src='/javascripts/dimazvali/geo.js')
    script(src='/javascripts/dimazvali/content.js')
    script(src='/javascripts/dimazvali/media.js')
    script(src='/javascripts/dimazvali/web.js')