      ::selection { background: #15120f; color: #f4f1ea; }

      .card-link { display: block; position: relative; min-height: clamp(380px,46vw,520px); overflow: hidden; background: #15120f; transition: transform .35s ease; }
      .card-link:hover { transform: translateY(-4px); }
      .card-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .55s ease, opacity .35s ease; }
      .card-link:hover .card-img { transform: scale(1.04); opacity: .95 !important; }

      @media (prefers-reduced-motion: reduce) {
        .card-link, .card-link:hover { transform: none; }
        .card-img { transition: none; }
      }

