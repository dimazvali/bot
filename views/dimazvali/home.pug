    script.
      (function() {
        // Logo popup
        var logo  = document.querySelector('.site-logo');
        var popup = document.querySelector('.logo-popup');
        if (logo && popup) {
          logo.addEventListener('click', function(e) {
            e.stopPropagation();
            var open = popup.classList.toggle('is-open');
            logo.setAttribute('aria-expanded', open);
            popup.setAttribute('aria-hidden', !open);
          });
          logo.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); logo.click(); }
            if (e.key === 'Escape') { popup.classList.remove('is-open'); logo.setAttribute('aria-expanded', 'false'); }
          });
          document.addEventListener('click', function() {
            popup.classList.remove('is-open');
            logo.setAttribute('aria-expanded', 'false');
            popup.setAttribute('aria-hidden', 'true');
          });
        }

        // Tbilisi time (UTC+4)
        function updateTbilisiTime() {
          var now = new Date(Date.now() + 4 * 3600000);
          var h = now.getUTCHours();
          var m = now.getUTCMinutes();
          var hh = String(h).padStart(2, '0');
          var mm = String(m).padStart(2, '0');
          var time = hh + ':' + mm;
          var ft = document.getElementById('footer-time');
          if (ft) ft.textContent = h < 12 ? 'учтите, у меня ' + time + ' утра' : 'учтите, у меня ' + time;
        }
        updateTbilisiTime();
        setInterval(updateTbilisiTime, 60000);

        // Hero greeting (set once)
        (function() {
          var h = new Date(Date.now() + 4 * 3600000).getUTCHours();
          var g = h >= 6 && h < 12 ? 'დილა მშვიდობისა'
                : h >= 12 && h < 18 ? 'შუადღე მშვიდობისა'
                : h >= 18 && h < 23 ? 'საღამო მშვიდობისა'
                : 'ღამე მშვიდობისა';
          document.getElementById('geo-greeting').textContent = g;
        }());

        // Name scramble animation
        var el = document.getElementById('hero-name');
        if (!el || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        var variants = [
          ['Дмитрий', 'Шестаков'],
          ['Dmitry',  'Shestakov'],
          ['დმიტრი',  'შესტაკოვი'],
        ];
        var pool = 'абвгдежзийклмнопрстухцчшщыэ' + 'abcdefghijkmnopqrstuvxyz' + 'აბგდევზთიკლმნოპრსტუფქღშჩცძწჭხჯჰ';

        var idx = 0;
        var current = variants[0];
        var queues, frame, raf;

        function rand() { return pool[Math.floor(Math.random() * pool.length)]; }

        function setText(newPair) {
          var oldPair = current;
          current = newPair;
          queues = [0, 1].map(function(w) {
            var from = oldPair[w] || '', to = newPair[w] || '';
            var len = Math.max(from.length, to.length), q = [];
            for (var i = 0; i < len; i++) {
              var start = Math.floor(Math.random() * 22);
              q.push({ fromC: from[i] || '', toC: to[i] || '', start: start, end: start + 12 + Math.floor(Math.random() * 24), char: null });
            }
            return q;
          });
          frame = 0;
          cancelAnimationFrame(raf);
          update();
        }

        function update() {
          var done = true;
          var out = queues.map(function(q) {
            var s = '';
            for (var i = 0; i < q.length; i++) {
              var it = q[i];
              if (frame >= it.end) {
                s += it.toC;
              } else if (frame >= it.start) {
                done = false;
                if (it.char === null || Math.random() < 0.3) it.char = rand();
                s += '<span style="opacity:.5;font-weight:500">' + it.char + '</span>';
              } else {
                done = false;
                s += it.fromC;
              }
            }
            return s;
          });
          el.innerHTML = out[0] + '<br>' + out[1];
          frame++;
          if (!done) raf = requestAnimationFrame(update);
        }

        setInterval(function() {
          idx = (idx + 1) % variants.length;
          setText(variants[idx]);
        }, 3400);
      }());
